    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "sync:missing": "tsx --tsconfig tsconfig.json scripts/sync-missing-persons.ts",
    "sync:damage": "tsx --tsconfig tsconfig.json scripts/sync-damage-map.ts",
