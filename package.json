    "react-leaflet": "^5.0.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.18",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "prisma": "^6.19.3",
    "typescript": "^5.8.3",
    "tsx": "^4.20.3"
  }
