{
  "name": "emergency-center",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "bash scripts/run-build.sh",
    "build:astro": "prisma generate && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "tsx --tsconfig tsconfig.json scripts/db-push-guard.ts",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "sync:missing": "tsx --tsconfig tsconfig.json scripts/sync-missing-persons.ts",
    "sync:missing:remote": "tsx --tsconfig tsconfig.json scripts/sync-missing-remote.ts",
    "sync:damage": "tsx --tsconfig tsconfig.json scripts/sync-damage-map.ts",
    "sync:damage:remote": "tsx --tsconfig tsconfig.json scripts/sync-damage-remote.ts",
    "fetch:damage": "tsx scripts/fetch-damage-map.ts",
    "fetch:pets": "tsx scripts/fetch-missing-pets.ts",
    "fetch:centroacopio": "tsx --tsconfig tsconfig.json scripts/fetch-centroacopio.ts",
    "sync:help-centers": "tsx --tsconfig tsconfig.json scripts/sync-help-centers.ts",
    "sync:centroacopio-deliveries": "tsx --tsconfig tsconfig.json scripts/sync-centroacopio-deliveries.ts",
    "sync:all": "tsx --tsconfig tsconfig.json scripts/sync-all.ts",
    "admin:create": "tsx --tsconfig tsconfig.json scripts/create-admin.ts",
    "sync:hospitals": "tsx --tsconfig tsconfig.json scripts/sync-hospitals.ts",
    "fetch:hospitals": "tsx scripts/fetch-venezuela-hospitals.ts",
    "fetch:hospitals:google": "tsx scripts/fetch-google-hospitals.ts"
  },
  "dependencies": {
    "@astrojs/react": "^4.3.0",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^8.2.0",
    "@prisma/client": "^6.9.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "astro": "^5.8.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.18",
    "@types/node": "^20.19.43",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
