---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import CommunityFeedback from "@/components/community/CommunityFeedback";
import ChildrenEmergencyRegistry from "@/components/registry/ChildrenEmergencyRegistry";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import {
  getChildrenEmergencyStats,
  NEXOSIGNAL_NINOS,
  RED_AYUDA_NINOS,
} from "@/data/children-emergency";
import {
  computeChildrenEmergencyStats,
  fetchLiveChildrenEmergencyCases,
  listChildEmergencyHospitals,
} from "@/lib/children-emergency/feed";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t, dict } = useTranslations(locale);
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;
const redAyudaStats = getChildrenEmergencyStats();
const protectionItems = dict.children.protection.items as string[];

let registryStats = { total: 0, nexosignal: 0, redayuda: 0, last_synced_at: null as string | null };
let hospitals: string[] = [];

try {
  const allCases = await fetchLiveChildrenEmergencyCases();
  registryStats = computeChildrenEmergencyStats(allCases);
  hospitals = listChildEmergencyHospitals(allCases);
} catch (err) {
  console.error("[ninos] failed to load children registry stats:", err);
}

const registryLabels = {
  ...dict.children.registry,
  noResults: t("common.noResults"),
};

const syncedLabel = (registryStats.last_synced_at ?? redAyudaStats.fetchedAt)
  ? new Date(registryStats.last_synced_at ?? redAyudaStats.fetchedAt!).toLocaleString(
      locale === "es" ? "es-VE" : "en-US",
      { dateStyle: "short", timeStyle: "short" }
    )
  : null;
---

<BaseLayout locale={locale} title={t("children.title")} description={t("children.subtitle")}>
  <PageHeader
    title={t("children.title")}
    subtitle={t("children.subtitle")}
    imageSrc="/images/headers/salud-rescate.svg"
    imageAlt={locale === "es" ? "Nios rescatados tras el terremoto" : "Rescued children after the earthquake"}
  />

  <div class="container-app pb-16 space-y-16 -mt-4">
    <section class="max-w-3xl">
      <div class="rounded-2xl border border-emergency/30 bg-emergency-muted/30 p-5 text-sm text-ink-secondary">
        {t("children.disclaimer")}
      </div>
    </section>

    {
      redAyudaStats.redAyudaChildren != null && (
        <section class="max-w-3xl">
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            <div class="card border-accent/25 bg-accent-muted/20 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-accent">
                {t("children.stats.redAyudaLabel")}
              </p>
              <p class="mt-1 text-3xl font-bold tabular-nums text-ink">{redAyudaStats.redAyudaChildren}</p>
            </div>
            {
              redAyudaStats.redAyudaReports != null && (
                <div class="card p-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-ink-muted">
                    {t("children.stats.reportsLabel")}
                  </p>
                  <p class="mt-1 text-3xl font-bold tabular-nums text-ink">{redAyudaStats.redAyudaReports}</p>
                </div>
              )
            }
            {
              registryStats.total > 0 && (
                <div class="card p-4">
                  <p class="text-xs font-semibold uppercase tracking-wide text-ink-muted">
                    {t("children.registry.title")}
                  </p>
                  <p class="mt-1 text-3xl font-bold tabular-nums text-ink">{registryStats.total}</p>
                  {
                    syncedLabel && (
                      <p class="mt-1 text-xs text-ink-muted">
                        {t("children.registry.lastSynced")}: {syncedLabel}
                      </p>
                    )
                  }
                </div>
              )
            }
          </div>
        </section>
      )
    }

    <section id="registro-ninos">
      <div class="mb-8 max-w-3xl">
        <h2 class="text-2xl font-bold text-ink">{t("children.registry.title")}</h2>
        <p class="mt-2 text-sm text-ink-secondary">{t("children.registry.subtitle")}</p>
        {
          syncedLabel && (
            <p class="mt-2 text-xs text-ink-muted">
              {t("children.registry.lastSynced")}: {syncedLabel}
              {registryStats.nexosignal > 0 && (
                <span>
                  {" "}
                   Nexo Signal: {registryStats.nexosignal}  Red Ayuda: {registryStats.redayuda}
                </span>
              )}
            </p>
          )
        }
      </div>

      <ChildrenEmergencyRegistry
        client:load
        locale={locale}
        hospitals={hospitals}
        labels={registryLabels}
        initialStats={registryStats}
      />
    </section>

    <section class="grid gap-6 lg:grid-cols-2" id="plataformas-ninos">
      <article
        class="overflow-hidden rounded-3xl border-2 border-emergency/40 bg-gradient-to-br from-emergency-muted/40 via-surface to-surface shadow-sm"
        id="nexosignal-ninos-de-pie"
      >
        <div class="p-6 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-wide text-emergency">
            {NEXOSIGNAL_NINOS.organization}
          </p>
          <h2 class="mt-2 text-2xl font-bold text-ink">{t("children.platforms.nexosignal.title")}</h2>
          <p class="mt-3 text-sm leading-relaxed text-ink-secondary">
            {t("children.platforms.nexosignal.description")}
          </p>
          <ul class="mt-4 space-y-2 text-sm text-ink-secondary">
            {
              (dict.children.platforms.nexosignal.features as string[]).map((item) => (
                <li class="flex gap-2">
                  <span class="text-emergency" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={NEXOSIGNAL_NINOS.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              {t("children.platforms.nexosignal.searchCta")} ?
            </a>
            <a
              href={NEXOSIGNAL_NINOS.reportUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              {t("children.platforms.nexosignal.reportCta")} ?
            </a>
          </div>
          <p class="mt-4 text-xs text-ink-muted">{NEXOSIGNAL_NINOS.domain}</p>
        </div>
        <div class="border-t border-border px-6 pb-6 sm:px-8">
          <CommunityFeedback
            client:visible
            contentType="external_link"
            contentId={NEXOSIGNAL_NINOS.id}
            locale={locale}
            labels={feedbackLabels}
            confidenceLabels={confidenceLabels}
            compact
          />
        </div>
      </article>

      <article
        class="overflow-hidden rounded-3xl border-2 border-accent/40 bg-gradient-to-br from-accent/10 via-surface to-surface shadow-sm"
        id="red-ayuda-ninos"
      >
        <div class="p-6 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-wide text-accent">
            {RED_AYUDA_NINOS.organization}
          </p>
          <h2 class="mt-2 text-2xl font-bold text-ink">{t("children.platforms.redayuda.title")}</h2>
          <p class="mt-3 text-sm leading-relaxed text-ink-secondary">
            {t("children.platforms.redayuda.description")}
          </p>
          <ul class="mt-4 space-y-2 text-sm text-ink-secondary">
            {
              (dict.children.platforms.redayuda.features as string[]).map((item) => (
                <li class="flex gap-2">
                  <span class="text-accent" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={RED_AYUDA_NINOS.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary"
            >
              {t("children.platforms.redayuda.searchCta")} ?
            </a>
            <a
              href={RED_AYUDA_NINOS.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              {t("children.platforms.redayuda.reportCta")} ?
            </a>
          </div>
          <p class="mt-4 text-xs text-ink-muted">redayudavenezuela.com/ninos</p>
        </div>
        <div class="border-t border-border px-6 pb-6 sm:px-8">
          <CommunityFeedback
            client:visible
            contentType="external_link"
            contentId={RED_AYUDA_NINOS.id}
            locale={locale}
            labels={feedbackLabels}
            confidenceLabels={confidenceLabels}
            compact
          />
        </div>
      </article>
    </section>

    <section class="max-w-3xl rounded-2xl border border-warning/30 bg-warning-muted/30 p-6" id="proteccion-infantil">
      <h2 class="text-xl font-semibold text-ink">{t("children.protection.title")}</h2>
      <p class="mt-2 text-sm text-ink-secondary">{t("children.protection.subtitle")}</p>
      <ol class="mt-5 list-decimal space-y-3 pl-5 text-sm text-ink-secondary">
        {protectionItems.map((item) => <li>{item}</li>)}
      </ol>
      <p class="mt-5 text-xs text-ink-muted">{t("children.protection.source")}</p>
    </section>

    <section class="grid gap-4 max-w-3xl sm:grid-cols-2">
      <a
        href={localePath(locale, "desaparecidos")}
        class="card-interactive block p-5 no-underline"
      >
        <h3 class="font-semibold text-ink">{t("children.crosslinks.missingTitle")}</h3>
        <p class="mt-2 text-sm text-ink-secondary">{t("children.crosslinks.missingDescription")}</p>
        <span class="mt-3 inline-block text-sm font-medium text-accent">
          {t("children.crosslinks.missingCta")} ?
        </span>
      </a>
      <a href={localePath(locale, "mascotas")} class="card-interactive block p-5 no-underline">
        <h3 class="font-semibold text-ink">{t("children.crosslinks.petsTitle")}</h3>
        <p class="mt-2 text-sm text-ink-secondary">{t("children.crosslinks.petsDescription")}</p>
        <span class="mt-3 inline-block text-sm font-medium text-accent">
          {t("children.crosslinks.petsCta")} ?
        </span>
      </a>
    </section>
  </div>
</BaseLayout>
