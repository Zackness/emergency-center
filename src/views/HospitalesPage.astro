---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import HospitalDirectory from "@/components/hospitals/HospitalDirectory";
import CommunityFeedback from "@/components/community/CommunityFeedback";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { fetchHospitals } from "@/lib/data";
import { HOSPITALS_DATA_SOURCE, HOSPITALS_DATA_ATTRIBUTION, HOSPITALS_TOTAL_COUNT } from "@/data/hospitals";
import { VENEZUELA_STATES } from "@/data/seed";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t, dict } = useTranslations(locale);
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;
const hospitals = await fetchHospitals();

const statesInData = [...new Set(hospitals.map((h) => h.state))].sort((a, b) =>
  a.localeCompare(b, "es")
);
const filterStates = [
  ...VENEZUELA_STATES.filter((s) => statesInData.includes(s)),
  ...statesInData.filter((s) => !VENEZUELA_STATES.includes(s as (typeof VENEZUELA_STATES)[number])),
];

const directoryLabels = {
  searchPlaceholder: t("hospitals.hub.searchPlaceholder"),
  filterState: t("hospitals.hub.filterState"),
  allStates: t("hospitals.hub.filterAll"),
  filterType: t("hospitals.filterType"),
  allTypes: t("hospitals.allTypes"),
  typeHospital: t("hospitals.typeHospital"),
  typeClinic: t("hospitals.typeClinic"),
  showing: t("hospitals.showing"),
  of: t("hospitals.of"),
  phone: t("common.phone"),
  directions: t("common.directions"),
  socialMedia: t("common.socialMedia"),
  operational: t("common.operational"),
  limited: t("common.limited"),
  closed: t("common.closed"),
  unknown: t("common.unknown"),
  dataSource:
    locale === "es"
      ? `Listado de ${HOSPITALS_TOTAL_COUNT} hospitales y clínicas con dirección según ${HOSPITALS_DATA_SOURCE}${HOSPITALS_DATA_ATTRIBUTION ? `. ${HOSPITALS_DATA_ATTRIBUTION}` : ""}. Verifica en el lugar antes de desplazarte.`
      : `Directory of ${HOSPITALS_TOTAL_COUNT} hospitals and clinics with addresses from ${HOSPITALS_DATA_SOURCE}${HOSPITALS_DATA_ATTRIBUTION ? `. ${HOSPITALS_DATA_ATTRIBUTION}` : ""}. Verify on site before traveling.`,
  noResults: t("hospitals.hub.empty"),
  loadMore: t("hospitals.hub.loadMore"),
};
---

<BaseLayout locale={locale} title={t("hospitals.title")}>
  <PageHeader title={t("hospitals.title")} subtitle={t("hospitals.subtitle")} imageSrc="/images/headers/salud-rescate.svg" imageAlt="">
    <section class="mb-8 max-w-3xl" id="hospitales-en-venezuela">
      <div class="card border-accent/30 bg-accent-muted/20 p-5 sm:p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-accent">
          {t("hospitals.admissionsRegistry.eyebrow")}
        </p>
        <h2 class="mt-1 text-xl font-bold text-ink">{t("hospitals.admissionsRegistry.title")}</h2>
        <p class="mt-2 text-sm text-ink-secondary">{t("hospitals.admissionsRegistry.description")}</p>
        <p class="mt-2 text-xs text-ink-muted">{t("hospitals.admissionsRegistry.note")}</p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="https://hospitalesenvenezuela.com"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            {t("hospitals.admissionsRegistry.cta")}
          </a>
          <a href={localePath(locale, "desaparecidos")} class="btn-secondary text-sm">
            {locale === "es" ? "Registro de desaparecidos" : "Missing persons registry"} →
          </a>
        </div>
        <CommunityFeedback
          client:visible
          contentType="external_link"
          contentId="hospitales-en-venezuela"
          locale={locale}
          labels={feedbackLabels}
          confidenceLabels={confidenceLabels}
          compact
        />
      </div>
    </section>

    <div class="rounded-2xl border border-border bg-surface-muted p-4 mb-8 text-sm text-ink-secondary max-w-3xl">
      {t("hospitals.socialFallback")}
    </div>

    <HospitalDirectory
      client:only="react"
      hospitals={hospitals}
      locale={locale}
      states={filterStates}
      labels={directoryLabels}
      feedbackLabels={feedbackLabels}
      confidenceLabels={confidenceLabels}
    />
  </PageHeader>
</BaseLayout>
