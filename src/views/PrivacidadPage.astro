---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import LegalDocument, { type LegalSection } from "@/components/legal/LegalDocument.astro";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t, dict } = useTranslations(locale);
const privacy = dict.legal.privacy as {
  title: string;
  subtitle: string;
  sections: LegalSection[];
};
---

<BaseLayout locale={locale} title={privacy.title} description={privacy.subtitle}>
  <PageHeader title={privacy.title} subtitle={privacy.subtitle} imageSrc="/images/headers/informacion-recursos.svg" imageAlt="" />
  <LegalDocument
    updatedLabel={t("legal.updatedLabel")}
    updatedAt={t("legal.updatedAt")}
    sections={privacy.sections}
    relatedLinks={[{ href: localePath(locale, "terminos"), label: t("footer.terms") }]}
  />
</BaseLayout>
