---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { PUBLIC_API_CATALOG } from "@/lib/public-api";
import { API_DOCS_HEADER } from "@/data/site-images";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t, dict } = useTranslations(locale);
const docs = dict.apiDocs as {
  title: string;
  subtitle: string;
  intro: string;
  baseUrlLabel: string;
  quickStartTitle: string;
  quickStartSteps: string[];
  limitsTitle: string;
  limitsBody: string;
  corsTitle: string;
  corsBody: string;
  endpointsTitle: string;
  alliedTitle: string;
  alliedBody: string;
  scrapeStatusTitle: string;
  scrapeStatusBody: string;
  examplesTitle: string;
};

const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const apiBase = `${siteOrigin}/api/v1`;
---

<BaseLayout locale={locale} title={docs.title} description={docs.subtitle} ogImage={API_DOCS_HEADER}>
  <PageHeader
    title={docs.title}
    subtitle={docs.subtitle}
    imageSrc={API_DOCS_HEADER}
    imageAlt={locale === "es" ? "Desarrolladores conectando datos de emergencia vía API" : "Developers connecting emergency data via API"}
  />

  <div class="container-app pb-16 pt-2 sm:pt-4">
    <article class="mx-auto max-w-3xl space-y-10 text-ink-secondary">
      <p class="text-base leading-relaxed text-ink sm:text-lg">{docs.intro}</p>

      <section class="rounded-2xl border border-border bg-surface-elevated p-5 sm:p-6 shadow-soft">
        <h2 class="text-lg font-semibold text-ink sm:text-xl">{docs.baseUrlLabel}</h2>
        <code class="mt-3 block overflow-x-auto rounded-xl bg-surface-muted px-4 py-3 text-sm font-mono text-ink">
          {apiBase}
        </code>
        <p class="mt-4 text-sm leading-relaxed">
          <a href={apiBase} class="text-accent hover:underline" target="_blank" rel="noopener">
            GET {apiBase}
          </a>
          {" "}— catálogo JSON de endpoints
        </p>
      </section>

      <section class="rounded-2xl border border-border bg-surface-elevated p-5 sm:p-6 shadow-soft">
        <h2 class="text-lg font-semibold text-ink sm:text-xl">{docs.quickStartTitle}</h2>
        <ol class="mt-4 list-decimal space-y-2 pl-5 text-sm leading-relaxed sm:text-base">
          {docs.quickStartSteps.map((step) => <li>{step}</li>)}
        </ol>
      </section>

      <section class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-2xl border border-border bg-surface-elevated p-5 shadow-soft">
          <h3 class="font-semibold text-ink">{docs.limitsTitle}</h3>
          <p class="mt-2 text-sm leading-relaxed">{docs.limitsBody}</p>
        </div>
        <div class="rounded-2xl border border-border bg-surface-elevated p-5 shadow-soft">
          <h3 class="font-semibold text-ink">{docs.corsTitle}</h3>
          <p class="mt-2 text-sm leading-relaxed">{docs.corsBody}</p>
        </div>
      </section>

      <section class="rounded-2xl border border-border bg-surface-elevated p-5 sm:p-6 shadow-soft">
        <h2 class="text-lg font-semibold text-ink sm:text-xl">{docs.examplesTitle}</h2>
        <div class="mt-5 space-y-5">
          <div>
            <p class="mb-2 text-sm font-medium text-ink">cURL — centros de acopio</p>
            <pre class="overflow-x-auto rounded-xl bg-surface-muted p-4 text-xs leading-relaxed sm:text-sm"><code>{`curl "${apiBase}/help-centers?limit=20"`}</code></pre>
          </div>
          <div>
            <p class="mb-2 text-sm font-medium text-ink">JavaScript fetch</p>
            <pre class="overflow-x-auto rounded-xl bg-surface-muted p-4 text-xs leading-relaxed sm:text-sm"><code>{`const res = await fetch("${apiBase}/missing-persons?status=missing&limit=10");
const data = await res.json();
console.log(data.items);`}</code></pre>
          </div>
          <div>
            <p class="mb-2 text-sm font-medium text-ink">Datos aliados por dominio</p>
            <pre class="overflow-x-auto rounded-xl bg-surface-muted p-4 text-xs leading-relaxed sm:text-sm"><code>{`curl "${apiBase}/allied-data?domain=donarseguro.com"`}</code></pre>
          </div>
        </div>
      </section>

      <section class="rounded-2xl border border-border bg-surface-elevated p-5 sm:p-6 shadow-soft">
        <h2 class="text-lg font-semibold text-ink sm:text-xl">{docs.alliedTitle}</h2>
        <p class="mt-2 text-sm leading-relaxed sm:text-base">{docs.alliedBody}</p>
        <pre class="mt-4 overflow-x-auto rounded-xl bg-surface-muted p-4 text-xs leading-relaxed sm:text-sm"><code>{`GET ${apiBase}/allied-data?domain={dominio}
GET ${apiBase}/allied-data?adapter={id}`}</code></pre>
      </section>

      <section class="rounded-2xl border border-border bg-surface-elevated p-5 sm:p-6 shadow-soft">
        <h2 class="text-lg font-semibold text-ink sm:text-xl">{docs.scrapeStatusTitle}</h2>
        <p class="mt-2 text-sm leading-relaxed sm:text-base">{docs.scrapeStatusBody}</p>
        <pre class="mt-4 overflow-x-auto rounded-xl bg-surface-muted p-4 text-xs leading-relaxed sm:text-sm"><code>{`curl "${apiBase}/scrape-status"`}</code></pre>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-ink sm:text-xl">{docs.endpointsTitle}</h2>
        <div class="mt-4 space-y-3">
          {
            PUBLIC_API_CATALOG.endpoints.map((endpoint) => (
              <article class="rounded-2xl border border-border bg-surface-elevated p-4 shadow-soft">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="inline-flex rounded-lg bg-accent-muted px-2.5 py-1 font-mono text-xs font-semibold text-accent">
                    {endpoint.method}
                  </span>
                  <code class="break-all font-mono text-xs text-ink sm:text-sm">{endpoint.path}</code>
                </div>
                <p class="mt-2 text-sm leading-relaxed">{endpoint.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <p class="text-sm">
        <a href={localePath(locale, "/")} class="text-accent hover:underline">← {t("nav.home")}</a>
      </p>
    </article>
  </div>
</BaseLayout>
