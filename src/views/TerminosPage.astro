---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import LegalDocument, { type LegalSection } from "@/components/legal/LegalDocument.astro";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t, dict } = useTranslations(locale);
const terms = dict.legal.terms as {
  title: string;
  subtitle: string;
  sections: LegalSection[];
};
---

<BaseLayout locale={locale} title={terms.title}>
  <PageHeader title={terms.title} subtitle={terms.subtitle} imageSrc="/images/headers/informacion-recursos.svg" imageAlt="" />
  <LegalDocument
    updatedLabel={t("legal.updatedLabel")}
    updatedAt={t("legal.updatedAt")}
    sections={terms.sections}
    relatedLinks={[{ href: localePath(locale, "privacidad"), label: t("footer.privacy") }]}
  />
</BaseLayout>
