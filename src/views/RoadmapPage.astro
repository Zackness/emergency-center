---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import RoadmapFeatureCard from "@/components/ui/RoadmapFeatureCard.astro";
import FeatureSuggestionForm from "@/components/forms/FeatureSuggestionForm";
import CommunityFeedback from "@/components/community/CommunityFeedback";
import { getRoadmapFeaturesByStatus } from "@/data/roadmap-features";
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t, dict } = useTranslations(locale);
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;

const inProgress = getRoadmapFeaturesByStatus("in_progress");
const planned = getRoadmapFeaturesByStatus("planned");
const shipped = getRoadmapFeaturesByStatus("shipped");

const statusLabels = dict.roadmap.status as Record<string, string>;
const categoryLabels = dict.roadmap.categories as Record<string, string>;
const formLabels = {
  ...dict.roadmap.form,
  submit: t("common.submit"),
};
---

<BaseLayout locale={locale} title={t("roadmap.title")} description={t("roadmap.subtitle")}>
  <PageHeader
    eyebrow={t("roadmap.eyebrow")}
    title={t("roadmap.title")}
    subtitle={t("roadmap.subtitle")}
    imageSrc="/images/headers/informacion-recursos.svg"
    imageAlt=""
  />

  <div class="container-app pb-16 space-y-16 -mt-4">
  <section>
    <div class="mb-6">
      <span class="eyebrow mb-2">{t("roadmap.inProgress.eyebrow")}</span>
      <h2 class="text-xl font-semibold text-ink">{t("roadmap.inProgress.title")}</h2>
      <p class="mt-1 text-sm text-ink-secondary max-w-2xl">{t("roadmap.inProgress.subtitle")}</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        inProgress.map((feature) => (
          <RoadmapFeatureCard
            feature={feature}
            locale={locale}
            statusLabels={statusLabels}
            categoryLabels={categoryLabels}
            viewLabel={t("roadmap.viewFeature")}
          >
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId={`roadmap-${feature.id}`}
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </RoadmapFeatureCard>
        ))
      }
    </div>
  </section>

  <section>
    <div class="mb-6">
      <span class="eyebrow mb-2">{t("roadmap.planned.eyebrow")}</span>
      <h2 class="text-xl font-semibold text-ink">{t("roadmap.planned.title")}</h2>
      <p class="mt-1 text-sm text-ink-secondary max-w-2xl">{t("roadmap.planned.subtitle")}</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        planned.map((feature) => (
          <RoadmapFeatureCard
            feature={feature}
            locale={locale}
            statusLabels={statusLabels}
            categoryLabels={categoryLabels}
            viewLabel={t("roadmap.viewFeature")}
          >
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId={`roadmap-${feature.id}`}
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </RoadmapFeatureCard>
        ))
      }
    </div>
  </section>

  <section>
    <div class="mb-6">
      <span class="eyebrow mb-2">{t("roadmap.shipped.eyebrow")}</span>
      <h2 class="text-xl font-semibold text-ink">{t("roadmap.shipped.title")}</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        shipped.map((feature) => (
          <RoadmapFeatureCard
            feature={feature}
            locale={locale}
            statusLabels={statusLabels}
            categoryLabels={categoryLabels}
            viewLabel={t("roadmap.viewFeature")}
          >
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId={`roadmap-${feature.id}`}
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </RoadmapFeatureCard>
        ))
      }
    </div>
  </section>

  <section id="sugerir" class="rounded-2xl border border-border bg-surface-muted/50 p-6 sm:p-8">
    <span class="eyebrow mb-3">{t("roadmap.suggest.eyebrow")}</span>
    <h2 class="text-xl font-semibold text-ink">{t("roadmap.suggest.title")}</h2>
    <p class="mt-2 mb-6 text-sm text-ink-secondary max-w-2xl">{t("roadmap.suggest.subtitle")}</p>
    <FeatureSuggestionForm
      client:load
      locale={locale}
      labels={formLabels}
      categories={categoryLabels}
    />
  </section>
  </div>
</BaseLayout>
