---
import CoordinatorLayout from "@/layouts/CoordinatorLayout.astro";
import ResetPasswordForm from "@/components/auth/ResetPasswordForm";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { getSessionUser } from "@/lib/auth-center";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t } = useTranslations(locale);

const user = await getSessionUser(Astro.request, Astro.cookies);
const accesoPath = localePath(locale, "centros-ayuda/acceso");
const error = Astro.url.searchParams.get("error");

const resetLabels = {
  title: t("coordinatorPortal.reset.title"),
  subtitle: t("coordinatorPortal.reset.subtitle"),
  password: t("coordinatorPortal.reset.password"),
  confirmPassword: t("coordinatorPortal.reset.confirmPassword"),
  submit: t("coordinatorPortal.reset.submit"),
  submitting: t("coordinatorPortal.reset.submitting"),
  mismatch: t("coordinatorPortal.reset.mismatch"),
  success: t("coordinatorPortal.reset.success"),
  loginLink: t("coordinatorPortal.reset.loginLink"),
  error: t("coordinatorPortal.reset.error"),
};
---

<CoordinatorLayout
  locale={locale}
  title={t("coordinatorPortal.reset.title")}
  description={t("coordinatorPortal.reset.subtitle")}
  current="acceso"
  userEmail={user?.email ?? undefined}
>
  {
    !user ? (
      <div class="mx-auto max-w-md card space-y-4">
        <p class="text-sm text-emergency">
          {error
            ? decodeURIComponent(error)
            : t("coordinatorPortal.reset.sessionRequired")}
        </p>
        <a href={accesoPath} class="btn-primary inline-flex">
          {t("coordinatorPortal.reset.requestLink")}
        </a>
      </div>
    ) : (
      <ResetPasswordForm client:load labels={resetLabels} loginPath={accesoPath} />
    )
  }
</CoordinatorLayout>
