---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import DonationNeedsList from "@/components/ui/DonationNeedsList.astro";
import HelpCenterPageIntro from "@/components/help-centers/HelpCenterPageIntro.astro";
import HelpCenterHub from "@/components/help-centers/HelpCenterHub";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { fetchHelpCenters } from "@/lib/data";
import { getHelpCenterImages } from "@/lib/help-centers";
import { HELP_CENTERS_HEADER } from "@/data/site-images";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t, dict } = useTranslations(locale);
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;
const centers = await fetchHelpCenters();

const centerViews = centers.map((center) => ({
  ...center,
  images: getHelpCenterImages(center),
}));

const hub = dict.helpCenters.hub;

const hubLabels = {
  hashtag: hub.hashtag,
  criticalTitle: hub.criticalTitle,
  criticalBody: hub.criticalBody,
  portals: hub.portals,
  zonesTitle: hub.zonesTitle,
  directoryTitle: hub.directoryTitle,
  directorySubtitle: hub.directorySubtitle,
  tabs: hub.tabs,
  filterCity: hub.filterCity,
  filterSector: hub.filterSector,
  allCities: hub.allCities,
  allSectors: hub.allSectors,
  searchSector: hub.searchSector,
  clearFilters: hub.clearFilters,
  noResults: hub.noResults,
  showing: hub.showing,
  of: hub.of,
  verified: hub.verified,
  phone: t("common.phone"),
  schedule: t("common.schedule"),
  directions: t("common.directions"),
  details: hub.details,
  needsSummary: hub.needsSummary,
  detail: {
    ...hub.detail,
    categories: dict.centerDashboard.categories as Record<string, string>,
    units: dict.centerDashboard.units as Record<string, string>,
    staffNeeded: dict.helpCenters.staffNeeded as Record<string, string>,
  },
  deliveryTabIntro: hub.deliveryTabIntro,
  deliveryTransportCta: hub.deliveryTransportCta,
  deliveryRegisterCta: hub.deliveryRegisterCta,
  alliedPlatform: hub.alliedPlatform,
  ayudaEncamino: hub.ayudaEncamino,
  panelCta: hub.panelCta,
  thirdPartyCta: hub.thirdPartyCta,
  logisticsBadge: dict.helpCenters.logistics.badge,
  logisticsTitle: dict.helpCenters.logistics.title,
  logisticsDescription: dict.helpCenters.logistics.description,
  logisticsFree: dict.helpCenters.logistics.free,
  centroacopioBadge: hub.centroacopioBadge,
  deliveryNoResults: hub.deliveryNoResults,
  deliveryVehicle: hub.deliveryVehicle,
  deliveryCoverage: hub.deliveryCoverage,
  activeAcopio: dict.helpCenters.activeAcopio,
  g3Caritas: dict.helpCenters.g3Caritas,
};

const typeLabels = Object.fromEntries(
  (["church", "community", "university", "government", "ngo"] as const).map((key) => [
    key,
    t(`helpCenters.types.${key}`),
  ]),
);

const acceptLabels = Object.fromEntries(
  (["water", "food", "medicine", "clothing", "hygiene", "bathroom_supplies", "blankets"] as const).map((key) => [
    key,
    t(`helpCenters.accepts.${key}`),
  ]),
);
---

<BaseLayout locale={locale} title={t("helpCenters.title")} description={t("helpCenters.subtitle")} ogImage={HELP_CENTERS_HEADER}>
  <PageHeader
    eyebrow={hub.heroBadge}
    title={hub.heroTitle}
    subtitle={hub.heroSubtitle}
    imageSrc={HELP_CENTERS_HEADER}
    imageAlt={locale === "es"
      ? "Voluntarios organizando agua, alimentos e insumos en un centro de acopio"
      : "Volunteers organizing water, food and supplies at a collection center"}
  />

  <div class="container-app space-y-10 py-8 sm:py-10">
    <HelpCenterPageIntro
      locale={locale}
      hashtag={hub.hashtag}
      criticalTitle={hub.criticalTitle}
      criticalBody={hub.criticalBody}
      portals={hub.portals}
      zonesTitle={hub.zonesTitle}
      registerPath={localePath(locale, "centros-ayuda/registrar")}
      volunteersRegisterPath={localePath(locale, "voluntarios")}
    />

    <HelpCenterHub
      client:load
      locale={locale}
      centers={centerViews}
      labels={hubLabels}
      typeLabels={typeLabels}
      acceptLabels={acceptLabels}
      feedbackLabels={feedbackLabels}
      confidenceLabels={confidenceLabels}
      registerPath={localePath(locale, "centros-ayuda/registrar")}
      registerThirdPartyPath={`${localePath(locale, "centros-ayuda/registrar")}?mode=third_party`}
      panelPath={localePath(locale, "centros-ayuda/panel")}
      volunteersPath={localePath(locale, "voluntarios")}
      volunteersTransportPath={`${localePath(locale, "voluntarios")}#carreras-gratis-acopio`}
      volunteersRegisterPath={localePath(locale, "voluntarios")}
      alliedPlatformUrl="https://centroacopio.site/"
      hideIntro
    />

    <DonationNeedsList
      locale={locale}
      feedbackLabels={feedbackLabels}
      confidenceLabels={confidenceLabels}
    />
  </div>
</BaseLayout>
