---
import "@/styles/global.css";
import AdminThemeInit from "@/components/admin/AdminThemeInit.astro";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
import Logo from "@/components/ui/Logo.astro";
import CenterSwitcher from "@/components/dashboard/CenterSwitcher";
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import type { CenterSection } from "@/lib/center-manage-page";
import { centerSectionPath, DEFAULT_CENTER_SECTION } from "@/lib/center-manage-page";

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  userEmail?: string;
  current?: "panel" | "register" | "acceso";
  mode?: "hub" | "center";
  centerId?: string;
  centerName?: string;
  centerSection?: CenterSection;
}

const {
  title,
  description,
  locale,
  userEmail,
  current = "panel",
  mode = "hub",
  centerId,
  centerName,
  centerSection = DEFAULT_CENTER_SECTION,
} = Astro.props;
const { t } = useTranslations(locale);

const panelPath = localePath(locale, "centros-ayuda/panel");
const registerPath = localePath(locale, "centros-ayuda/registrar");
const sitePath = locale === "es" ? "/" : `/${locale}`;

const hubNav = [
  { id: "panel" as const, href: panelPath, label: t("coordinatorPortal.nav.panel"), icon: "grid" },
  { id: "register" as const, href: registerPath, label: t("coordinatorPortal.nav.register"), icon: "plus" },
];

const centerNav = centerId
  ? [
      {
        id: "inventario" as const,
        href: centerSectionPath(locale, centerId, "inventario"),
        label: t("coordinatorPortal.centerNav.inventory"),
        icon: "box",
      },
      {
        id: "voluntarios" as const,
        href: centerSectionPath(locale, centerId, "voluntarios"),
        label: t("coordinatorPortal.centerNav.volunteers"),
        icon: "users",
      },
      {
        id: "centro" as const,
        href: centerSectionPath(locale, centerId, "centro"),
        label: t("coordinatorPortal.centerNav.settings"),
        icon: "settings",
      },
    ]
  : [];

const nav = mode === "center" ? centerNav : hubNav;
const activeNavId = mode === "center" ? centerSection : current;

const switcherLabels = {
  search: t("coordinatorPortal.switcher.search"),
  allCenters: t("coordinatorPortal.switcher.allCenters"),
  verified: t("coordinatorPortal.switcher.verified"),
  pending: t("coordinatorPortal.switcher.pending"),
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — {t("coordinatorPortal.brand")}</title>
    <AdminThemeInit />
  </head>
  <body class="min-h-screen bg-surface text-ink">
    <div class="flex min-h-screen">
      <aside class="hidden w-56 shrink-0 flex-col border-r border-border bg-surface-muted md:flex">
        {
          mode === "center" ? (
            <div class="border-b border-border px-4 py-4">
              <a
                href={panelPath}
                class="flex items-center gap-2 text-xs text-ink-muted transition-colors hover:text-ink"
              >
                ← {t("coordinatorPortal.manage.back")}
              </a>
              <div class="mt-3 flex items-center gap-2.5">
                <Logo size={24} />
                <div class="min-w-0">
                  <p class="truncate text-sm font-semibold text-ink">{centerName}</p>
                  <p class="text-xs text-ink-muted">{t("coordinatorPortal.centerNav.label")}</p>
                </div>
              </div>
            </div>
          ) : (
            <div class="border-b border-border px-4 py-5">
              <a href={panelPath} class="flex items-center gap-2.5">
                <Logo size={32} />
                <div class="min-w-0 leading-tight">
                  <p class="truncate text-sm font-semibold text-ink">Emergency Center</p>
                  <p class="truncate text-xs text-ink-muted">{t("coordinatorPortal.brand")}</p>
                </div>
              </a>
            </div>
          )
        }

        <nav class="flex-1 space-y-1 p-3" aria-label={t("coordinatorPortal.nav.label")}>
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors",
                  activeNavId === item.id
                    ? "bg-surface-elevated text-ink"
                    : "text-ink-secondary hover:bg-surface-muted/50 hover:text-ink",
                ]}
              >
                {item.icon === "grid" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect width="7" height="7" x="3" y="3" rx="1" /><rect width="7" height="7" x="14" y="3" rx="1" /><rect width="7" height="7" x="14" y="14" rx="1" /><rect width="7" height="7" x="3" y="14" rx="1" />
                  </svg>
                )}
                {item.icon === "plus" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14" /><path d="M12 5v14" />
                  </svg>
                )}
                {item.icon === "settings" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                )}
                {item.icon === "users" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                )}
                {item.icon === "box" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" /><path d="m3.3 7 8.7 5 8.7-5" /><path d="M12 22V12" />
                  </svg>
                )}
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="border-t border-border p-3">
          <a
            href={sitePath}
            class="flex items-center gap-2 rounded-lg px-3 py-2 text-xs text-ink-muted hover:bg-surface-muted/50 hover:text-ink"
          >
            {t("coordinatorPortal.viewSite")} →
          </a>
        </div>
      </aside>

      <div class="flex min-w-0 flex-1 flex-col">
        <header class="flex flex-wrap items-center justify-between gap-3 border-b border-border bg-surface-elevated px-4 py-2.5 md:px-6">
          <div class="flex min-w-0 flex-1 items-center gap-2 text-sm">
            <a
              href={panelPath}
              class="flex shrink-0 items-center gap-2 rounded-md transition-opacity hover:opacity-90"
              aria-label="Emergency Center"
            >
              <Logo size={28} />
            </a>
            <span class="text-ink-muted" aria-hidden="true">/</span>
            <a
              href={panelPath}
              class="hidden shrink-0 font-medium text-ink-secondary transition-colors hover:text-ink sm:inline"
            >
              {t("coordinatorPortal.switcher.allCenters")}
            </a>
            {
              mode === "center" && centerId && centerName && (
                <>
                  <span class="hidden text-ink-muted sm:inline" aria-hidden="true">/</span>
                  <div class="hidden min-w-0 sm:block">
                    <CenterSwitcher
                      client:load
                      locale={locale}
                      centerId={centerId}
                      centerName={centerName}
                      panelPath={panelPath}
                      labels={switcherLabels}
                    />
                  </div>
                  <h1 class="truncate font-semibold text-ink sm:hidden">{centerName}</h1>
                </>
              )
            }
            {
              mode === "hub" && (
                <>
                  <span class="text-ink-muted md:hidden" aria-hidden="true">/</span>
                  <h1 class="truncate font-semibold text-ink md:hidden">{title}</h1>
                  <div class="hidden md:block">
                    {description && <p class="text-sm text-ink-secondary">{description}</p>}
                  </div>
                </>
              )
            }
          </div>
          <div class="flex flex-wrap items-center gap-2 text-sm">
            <ThemeToggle locale={locale} />
            {userEmail && <span class="hidden text-ink-muted sm:inline">{userEmail}</span>}
            {
              userEmail ? (
                <form method="POST" action="/api/auth/logout">
                  <input type="hidden" name="redirect" value={localePath(locale, "centros-ayuda/acceso")} />
                  <button type="submit" class="btn-ghost text-xs text-ink-secondary">
                    {t("coordinatorPortal.logout")}
                  </button>
                </form>
              ) : (
                <a href={localePath(locale, "centros-ayuda/acceso")} class="btn-secondary text-xs">
                  {t("coordinatorPortal.signIn")}
                </a>
              )
            }
          </div>
        </header>

        <nav class="flex gap-2 border-b border-border bg-surface-muted p-2 md:hidden" aria-label={t("coordinatorPortal.nav.label")}>
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "flex-1 rounded-lg px-3 py-2 text-center text-xs font-medium",
                  activeNavId === item.id
                    ? "bg-accent text-white"
                    : "bg-surface-elevated text-ink-secondary",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <main class="flex-1 overflow-auto bg-surface p-4 md:p-8">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
