---
import "@/styles/global.css";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import EmergencyBar from "@/components/layout/EmergencyBar.astro";
import DevNoticeBar from "@/components/layout/DevNoticeBar.astro";
import type { Locale } from "@/i18n/config";
import { localePath, ogLocaleTag } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { buildSearchIndex } from "@/lib/search";
import {
  absoluteAssetUrl,
  buildOrganizationJsonLd,
  buildWebSiteJsonLd,
  DEFAULT_OG_IMAGE,
  hreflangAlternates,
  ogLocaleAlternates,
  SITE_NAME,
  TWITTER_HANDLE,
} from "@/lib/seo";
import type { SearchResultType } from "@/types/search";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  locale: Locale;
  noEmergencyBar?: boolean;
}

const { title, description, ogImage, locale, noEmergencyBar = false } = Astro.props;
const { t, dict } = useTranslations(locale);
const pageTitle = title ? `${title} — ${t("meta.title")}` : t("meta.title");
const pageDescription = description ?? dict.meta.description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = absoluteAssetUrl(Astro.site, ogImage ?? DEFAULT_OG_IMAGE);
const alternateLocales = hreflangAlternates(Astro.site, Astro.url.pathname);
const searchIndex = await buildSearchIndex(locale);
const categoryLabels = dict.search.categories as Record<SearchResultType, string>;
const searchLabels = {
  placeholder: t("search.placeholder"),
  placeholderShort: t("search.placeholderShort"),
  noResults: t("search.noResults"),
  resultsFor: t("search.resultsFor"),
  hint: t("search.hint"),
  external: t("search.external"),
  categories: categoryLabels,
};
const structuredData = [
  buildWebSiteJsonLd(Astro.site, locale),
  buildOrganizationJsonLd(Astro.site),
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta
      name="theme-color"
      content="#fafafa"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#09090b"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={ogLocaleTag(locale)} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={pageTitle} />
    {
      ogLocaleAlternates(locale).map((tag) => (
        <meta property="og:locale:alternate" content={tag} />
      ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content={TWITTER_HANDLE} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    {
      alternateLocales.map(({ locale: loc, href }) => (
        <link rel="alternate" hreflang={loc} href={href} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={alternateLocales.find(({ locale: loc }) => loc === "es")?.href ?? canonicalURL.href}
    />

    <title>{pageTitle}</title>
    {
      structuredData.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body class="min-h-screen flex flex-col">
    <script
      id="search-index-data"
      type="application/json"
      set:html={JSON.stringify(searchIndex)}
    />
    {!noEmergencyBar && <EmergencyBar locale={locale} />}
    <DevNoticeBar locale={locale} />
    <Header locale={locale} searchLabels={searchLabels} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    {
      import.meta.env.PROD && (
        <script is:inline defer src="/_vercel/insights/script.js" />
      )
    }
    <script is:inline define:vars={{ isProd: import.meta.env.PROD }}>
      if ("serviceWorker" in navigator) {
        if (isProd) {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        } else {
          navigator.serviceWorker
            .getRegistrations()
            .then((regs) => regs.forEach((reg) => reg.unregister()))
            .catch(() => {});
          if (window.caches) {
            caches
              .keys()
              .then((keys) => keys.forEach((key) => caches.delete(key)))
              .catch(() => {});
          }
        }
      }
    </script>
  </body>
</html>
