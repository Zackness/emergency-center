---
interface Props {
  title: string;
  description?: string | null;
  url: string;
  verified?: boolean;
  verifiedLabel?: string;
}

const { title, description, url, verified = false, verifiedLabel = "Verified" } = Astro.props;
---

<article class="card">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-2">
        <h3 class="font-semibold text-ink">{title}</h3>
        {verified && <span class="badge-verified">{verifiedLabel}</span>}
      </div>
      {description && <p class="mt-2 text-sm text-ink-secondary">{description}</p>}
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-secondary shrink-0 text-xs"
    >
      →
    </a>
  </div>
</article>
