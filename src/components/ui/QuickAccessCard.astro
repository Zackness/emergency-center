---
import Icon from "@/components/ui/Icon.astro";
import { getNavIconColor } from "@/lib/nav-icons";

interface Props {
  href: string;
  title: string;
  description: string;
  icon?: string;
  external?: boolean;
}

const { href, title, description, icon, external = false } = Astro.props;

const colorClass = getNavIconColor(icon);
---

<a
  href={href}
  class="card-interactive group flex items-start gap-4"
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
>
  <div class:list={["flex h-11 w-11 shrink-0 items-center justify-center rounded-xl transition-transform group-hover:scale-110", colorClass]}>
    <Icon name={icon ?? "map-pin"} size={20} />
  </div>
  <div class="flex-1">
    <div class="flex items-center justify-between gap-2">
      <h3 class="font-semibold text-ink transition-colors group-hover:text-accent">{title}</h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-ink-muted transition-all duration-200 group-hover:translate-x-1 group-hover:text-accent"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
    <p class="mt-1 text-sm text-ink-secondary">{description}</p>
  </div>
</a>
