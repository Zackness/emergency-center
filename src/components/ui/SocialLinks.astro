---
import type { SocialLink, SocialPlatform } from "@/types/social";

interface Props {
  links: SocialLink[];
  title?: string;
  compact?: boolean;
}

const { links, title, compact = false } = Astro.props;

const platformLabels: Record<SocialPlatform, string> = {
  instagram: "Instagram",
  twitter: "X",
  facebook: "Facebook",
  youtube: "YouTube",
  tiktok: "TikTok",
  whatsapp: "WhatsApp",
  telegram: "Telegram",
};
---

{
  links.length > 0 && (
    <div class:list={["mt-3", compact ? "" : "pt-3 border-t border-border"]}>
      {title && <p class="text-xs font-medium uppercase tracking-wide text-ink-muted mb-2">{title}</p>}
      <div class="flex flex-wrap gap-2">
        {links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-full border border-border bg-surface-muted px-3 py-1.5 text-xs font-medium text-ink-secondary hover:border-accent/40 hover:text-accent transition-colors"
          >
            <span>{platformLabels[link.platform]}</span>
            {link.handle && <span class="text-ink-muted">· {link.handle}</span>}
          </a>
        ))}
      </div>
    </div>
  )
}
