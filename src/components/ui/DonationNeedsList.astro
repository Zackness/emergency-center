---
import CommunityFeedback from "@/components/community/CommunityFeedback";
import { DONATION_NEED_CATEGORIES } from "@/data/donation-needs";
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import type { CommunityConfidenceLevel } from "@/types/community-feedback";

interface Props {
  locale: Locale;
  feedbackLabels?: Record<string, string>;
  confidenceLabels?: Record<CommunityConfidenceLevel, string>;
}

const { locale, feedbackLabels, confidenceLabels } = Astro.props;
const { t } = useTranslations(locale);
---

<section
  class="mb-8 rounded-2xl border border-ink/10 bg-surface p-6"
  id="que-donar"
  aria-labelledby="donation-needs-title"
>
  <h2 id="donation-needs-title" class="text-xl font-semibold text-ink">
    {t("helpCenters.needs.title")}
  </h2>
  <p class="mt-2 text-sm text-ink-secondary">{t("helpCenters.needs.subtitle")}</p>

  <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      DONATION_NEED_CATEGORIES.map((category) => (
        <div class="rounded-xl border border-ink/8 bg-surface-muted/50 p-4">
          <h3 class="text-sm font-semibold text-ink">
            {t(`helpCenters.needs.categories.${category.id}` as "helpCenters.needs.categories.wound-care")}
          </h3>
          <ul class="mt-3 space-y-1.5">
            {category.items.map((itemId) => (
              <li class="flex items-start gap-2 text-sm text-ink-secondary">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                <span>{t(`helpCenters.needs.items.${itemId}` as "helpCenters.needs.items.gauze")}</span>
              </li>
            ))}
          </ul>
          {
            feedbackLabels && confidenceLabels && (
              <CommunityFeedback
                client:visible
                contentType="external_link"
                contentId={`donation-needs-${category.id}`}
                locale={locale}
                labels={feedbackLabels}
                confidenceLabels={confidenceLabels}
                compact
              />
            )
          }
        </div>
      ))
    }
  </div>

  <p class="mt-5 text-xs text-ink-secondary">{t("helpCenters.needs.disclaimer")}</p>
</section>
