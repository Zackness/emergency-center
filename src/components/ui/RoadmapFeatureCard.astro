---
import type { RoadmapFeature, RoadmapFeatureStatus } from "@/data/roadmap-features";
import type { Locale } from "@/i18n/config";

interface Props {
  feature: RoadmapFeature;
  locale: Locale;
  statusLabels: Record<RoadmapFeatureStatus, string>;
  categoryLabels: Record<string, string>;
  viewLabel: string;
}

const { feature, locale, statusLabels, categoryLabels, viewLabel } = Astro.props;

const statusClass: Record<RoadmapFeatureStatus, string> = {
  in_progress: "bg-accent-muted text-accent",
  planned: "bg-warning-muted text-warning",
  shipped: "bg-success-muted text-success",
};

const href = feature.href ? `/${locale}${feature.href}` : null;
---

<article class="card-interactive group flex flex-col gap-4" id={feature.id}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
      <span class:list={["badge", statusClass[feature.status]]}>
        {statusLabels[feature.status]}
      </span>
      <span class="badge bg-surface-muted text-ink-secondary">
        {categoryLabels[feature.category] ?? feature.category}
      </span>
    </div>
    {
      feature.status === "in_progress" && feature.progress != null && (
        <span class="text-sm font-semibold tabular-nums text-accent">{feature.progress}%</span>
      )
    }
  </div>

  <div class="flex-1">
    <h3 class="font-semibold text-ink transition-colors group-hover:text-accent">
      {locale === "es" ? feature.title.es : feature.title.en}
    </h3>
    <p class="mt-2 text-sm text-ink-secondary">
      {locale === "es" ? feature.description.es : feature.description.en}
    </p>
  </div>

  {
    feature.status === "in_progress" && feature.progress != null && (
      <div class="h-1.5 overflow-hidden rounded-full bg-surface-muted">
        <div
          class="h-full rounded-full bg-accent transition-all duration-500"
          style={`width: ${feature.progress}%`}
        />
      </div>
    )
  }

  {
    href && (
      <a href={href} class="btn-ghost -ml-2 w-fit text-sm text-accent">
        {viewLabel} →
      </a>
    )
  }
  <slot />
</article>
