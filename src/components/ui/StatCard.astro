---
interface Props {
  value: string | number;
  label: string;
  icon?: string;
  accent?: "accent" | "success" | "warning" | "emergency";
}

const { value, label, icon, accent = "accent" } = Astro.props;

const icons: Record<string, string> = {
  "map-pin": "M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z",
  tent: "M3.5 21 12 3l8.5 18 M12 3v18",
  hospital: "M12 6v4 M14 14h-4 M14 18h-4 M14 8h-4 M18 2a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z",
  heart: "M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z",
};

const accentClasses: Record<string, string> = {
  accent: "bg-accent-muted text-accent",
  success: "bg-success-muted text-success",
  warning: "bg-warning-muted text-warning",
  emergency: "bg-emergency-muted text-emergency",
};
---

<div class="card flex items-center gap-4">
  {
    icon && (
      <div class:list={["flex h-12 w-12 shrink-0 items-center justify-center rounded-xl", accentClasses[accent]]}>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d={icons[icon] ?? icons["map-pin"]} />
        </svg>
      </div>
    )
  }
  <div>
    <div class="text-3xl font-bold tracking-tight text-ink tabular-nums">{value}</div>
    <div class="mt-0.5 text-sm text-ink-secondary">{label}</div>
  </div>
</div>
