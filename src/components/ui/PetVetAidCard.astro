---
import { phoneTelHref } from "@/lib/phone";

interface Props {
  anchorId: string;
  imageUrl: string;
  title: string;
  subtitle: string;
  body: string;
  channelLabel: string;
  locationLabel: string;
  location: string;
  instagramLabel: string;
  instagramUrl: string;
  handle: string;
  phoneLabel: string;
  phone: string;
  whatsappLabel: string;
  whatsappUrl: string;
}

const {
  anchorId,
  imageUrl,
  title,
  subtitle,
  body,
  channelLabel,
  locationLabel,
  location,
  instagramLabel,
  instagramUrl,
  handle,
  phoneLabel,
  phone,
  whatsappLabel,
  whatsappUrl,
} = Astro.props;
---

<article
  class="card border-emergency/20 bg-emergency-muted/10 mb-10"
  id={anchorId}
>
  <span class="badge-emergency mb-3">{channelLabel}</span>
  <div class="grid gap-6 md:grid-cols-2">
    <img
      src={imageUrl}
      alt={title}
      class="w-full rounded-xl border border-zinc-200/80 object-contain bg-surface-elevated max-h-[520px]"
      loading="lazy"
    />
    <div>
      <h2 class="text-xl font-semibold text-ink">{title}</h2>
      <p class="mt-2 text-sm font-medium text-ink-secondary">{subtitle}</p>
      <p class="mt-3 text-sm text-ink-secondary leading-relaxed">{body}</p>

      <p class="mt-4 text-sm text-ink">
        <span class="font-medium text-ink-muted">{locationLabel}:</span> {location}
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={phoneTelHref(phone)} class="btn-primary">
          {phoneLabel}: {phone}
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          {whatsappLabel} →
        </a>
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          {instagramLabel} {handle} →
        </a>
      </div>
    </div>
  </div>
  <slot />
</article>
