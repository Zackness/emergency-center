---
import { getNavIconPaths } from "@/lib/nav-icons";

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 20, class: className } = Astro.props;
const paths = getNavIconPaths(name);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {paths.map((d) => <path d={d} />)}
</svg>
