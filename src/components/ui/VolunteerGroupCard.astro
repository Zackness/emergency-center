---
interface Props {
  anchorId: string;
  badge: string;
  title: string;
  body: string;
  priorityLabel: string;
  priorityText: string;
  joinLabel: string;
  joinUrl: string;
  displayPath: string;
  shareLabel: string;
  imageUrl?: string | null;
  linkNote?: string;
}

const {
  anchorId,
  badge,
  title,
  body,
  priorityLabel,
  priorityText,
  joinLabel,
  joinUrl,
  displayPath,
  shareLabel,
  imageUrl,
  linkNote,
} = Astro.props;
---

<article class="card border-accent/25 bg-accent-muted/15 mb-10" id={anchorId}>
  <div class:list={["grid gap-6", imageUrl ? "lg:grid-cols-2" : ""]}>
    {
      imageUrl && (
        <img
          src={imageUrl}
          alt={title}
          class="w-full rounded-xl border border-zinc-200/80 object-contain bg-surface-elevated max-h-[320px]"
          loading="lazy"
        />
      )
    }
    <div>
      <span class="text-xs font-semibold uppercase tracking-wide text-accent">{badge}</span>
      <h2 class="mt-2 text-xl font-semibold text-ink">{title}</h2>
      <p class="mt-4 text-sm text-ink-secondary leading-relaxed">{body}</p>

      <dl class="mt-5 text-sm">
        <div>
          <dt class="text-ink-muted font-medium">{priorityLabel}</dt>
          <dd class="mt-1 text-ink">{priorityText}</dd>
        </div>
      </dl>

      {linkNote && <p class="mt-3 text-xs text-ink-muted">{linkNote}</p>}

      <div class="mt-6">
        <a
          href={joinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          {joinLabel}: {displayPath} →
        </a>
      </div>

      <p class="mt-4 text-xs text-ink-muted">{shareLabel}</p>
    </div>
  </div>
  <slot />
</article>
