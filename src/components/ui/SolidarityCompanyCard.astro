---
import { phoneTelHref } from "@/lib/phone";

interface Props {
  id: string;
  name: string;
  description: string;
  resources: string[];
  resourceLabels: Record<string, string>;
  coverage: string;
  resourcesLabel: string;
  coverageLabel: string;
  websiteUrl?: string;
  websiteLabel: string;
  instagramUrl?: string;
  instagramLabel: string;
  phone?: string;
  phoneLabel: string;
  helpCenterHref?: string;
  helpCenterLabel: string;
  verified?: boolean;
  verifiedLabel?: string;
  sourcePublishedAt?: string;
  sourcePublishedLabel?: string;
  locale?: string;
}

const {
  id,
  name,
  description,
  resources,
  resourceLabels,
  coverage,
  resourcesLabel,
  coverageLabel,
  websiteUrl,
  websiteLabel,
  instagramUrl,
  instagramLabel,
  phone,
  phoneLabel,
  helpCenterHref,
  helpCenterLabel,
  verified,
  verifiedLabel,
  sourcePublishedAt,
  sourcePublishedLabel,
  locale = "es",
} = Astro.props;

function formatPublishedAt(iso: string, locale: string): string {
  const date = new Date(iso);
  if (Number.isNaN(date.getTime())) return iso;
  return new Intl.DateTimeFormat(locale === "es" ? "es-VE" : "en-US", {
    dateStyle: "long",
    timeStyle: "short",
    timeZone: "America/Caracas",
  }).format(date);
}
---

<article class="card" id={id}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="font-semibold text-ink text-lg">{name}</h3>
        {verified && verifiedLabel && (
          <span class="badge-verified">{verifiedLabel}</span>
        )}
      </div>
      <p class="mt-2 text-sm text-ink-secondary leading-relaxed">{description}</p>
      {sourcePublishedAt && sourcePublishedLabel && (
        <p class="mt-2 text-xs text-ink-muted">
          {sourcePublishedLabel}: {formatPublishedAt(sourcePublishedAt, locale)}
        </p>
      )}
    </div>
  </div>

  <dl class="mt-4 grid gap-3 sm:grid-cols-2 text-sm">
    <div>
      <dt class="text-xs font-medium uppercase tracking-wide text-ink-muted">{coverageLabel}</dt>
      <dd class="mt-1 text-ink-secondary">{coverage}</dd>
    </div>
    <div>
      <dt class="text-xs font-medium uppercase tracking-wide text-ink-muted">{resourcesLabel}</dt>
      <dd class="mt-1 flex flex-wrap gap-1.5">
        {
          resources.map((key) => (
            <span class="badge bg-surface-muted text-ink-secondary">
              {resourceLabels[key] ?? key}
            </span>
          ))
        }
      </dd>
    </div>
  </dl>

  <div class="mt-4 flex flex-wrap gap-3 border-t border-border pt-4">
    {
      helpCenterHref && (
        <a href={helpCenterHref} class="btn-primary text-sm">
          {helpCenterLabel} →
        </a>
      )
    }
    {
      websiteUrl && (
        <a
          href={websiteUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary text-sm"
        >
          {websiteLabel} →
        </a>
      )
    }
    {
      instagramUrl && (
        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary text-sm"
        >
          {instagramLabel} →
        </a>
      )
    }
    {
      phone && (
        <a href={phoneTelHref(phone)} class="btn-secondary text-sm">
          {phoneLabel}: {phone}
        </a>
      )
    }
  </div>
</article>
