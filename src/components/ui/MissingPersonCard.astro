---
import type { MissingPersonVerificationStatus } from "@/types";

interface SourceItem {
  id: string;
  source_name: string;
  external_url: string | null;
  is_external: boolean;
}

interface Props {
  id?: string;
  fullName: string;
  age?: number | null;
  state: string;
  city: string;
  lastSeenLocation?: string | null;
  verificationStatus: MissingPersonVerificationStatus;
  verificationLabel: string;
  sources: SourceItem[];
  sourcesLabel: string;
  locationLabel: string;
}

const {
  id,
  fullName,
  age,
  state,
  city,
  lastSeenLocation,
  verificationStatus,
  verificationLabel,
  sources,
  sourcesLabel,
  locationLabel,
} = Astro.props;

const statusClass =
  verificationStatus === "family_verified" || verificationStatus === "org_verified"
    ? "badge-verified"
    : verificationStatus === "found"
      ? "bg-success-muted text-success rounded-full px-2.5 py-0.5 text-xs font-medium"
      : verificationStatus === "deceased"
        ? "bg-surface-muted text-ink-muted rounded-full px-2.5 py-0.5 text-xs font-medium"
        : "badge-warning";
---

<article class="card" id={id}>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h3 class="font-semibold text-ink text-lg">
        {fullName}
        {age != null && <span class="text-ink-secondary font-normal">, {age}</span>}
      </h3>
      <p class="mt-1 text-sm text-ink-secondary">
        {locationLabel}: {city}, {state}
        {lastSeenLocation && ` — ${lastSeenLocation}`}
      </p>
    </div>
    <span class={statusClass}>{verificationLabel}</span>
  </div>

  {sources.length > 0 && (
    <div class="mt-4 border-t border-border pt-4">
      <p class="text-xs font-medium uppercase tracking-wide text-ink-muted mb-2">{sourcesLabel}</p>
      <ul class="space-y-2">
        {sources.map((source) => (
          <li class="flex items-center justify-between gap-2 text-sm">
            <span class="text-ink-secondary">
              {source.is_external ? "↗" : "●"} {source.source_name}
            </span>
            {source.external_url && (
              <a
                href={source.external_url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline shrink-0"
              >
                →
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  )}
</article>
