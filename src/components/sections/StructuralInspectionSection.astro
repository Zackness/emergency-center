---
import StructuralInspectionCard from "@/components/ui/StructuralInspectionCard.astro";
import CommunityFeedback from "@/components/community/CommunityFeedback";
import {
  getStructuralInspectionCompanies,
  getStructuralInspectionServices,
  getStructuralInspectionVolunteers,
} from "@/data/structural-inspection-services";
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import en from "@/i18n/locales/en.json";

interface Props {
  locale: Locale;
  filter?: "volunteer" | "company" | "all";
  sectionId?: string;
  titleKey?: string;
  subtitleKey?: string;
}

const {
  locale,
  filter = "all",
  sectionId = "inspecciones-estructurales",
  titleKey = "damage.structuralInspection.title",
  subtitleKey = "damage.structuralInspection.subtitle",
} = Astro.props;

const { t, dict } = useTranslations(locale);
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;
const labels =
  (dict.damage as { structuralInspection?: Record<string, string> }).structuralInspection ??
  en.damage.structuralInspection;

const services =
  filter === "volunteer"
    ? getStructuralInspectionVolunteers()
    : filter === "company"
      ? getStructuralInspectionCompanies()
      : getStructuralInspectionServices();
---

<section class="mb-12" id={sectionId}>
  <div class="mb-6 max-w-3xl">
    <h2 class="text-xl font-semibold text-ink">{t(titleKey)}</h2>
    <p class="mt-1 text-sm text-ink-secondary">{t(subtitleKey)}</p>
    <p class="mt-3 rounded-2xl border border-warning/30 bg-warning-muted/40 px-4 py-3 text-xs text-ink-secondary">
      {labels.disclaimer}
    </p>
  </div>
  <div class="grid gap-4 max-w-4xl sm:grid-cols-2">
    {
      services.map((service) => (
        <div>
          <StructuralInspectionCard
            service={service}
            locale={locale}
            servicesLabel={labels.servicesLabel}
            coverageLabel={labels.coverageLabel}
            phoneLabel={t("common.phone")}
            whatsappLabel={labels.whatsappLabel}
            instagramLabel={t("companies.directory.instagram")}
            websiteLabel={t("companies.directory.visitWebsite")}
            verifiedLabel={t("common.verified")}
            volunteerBadge={labels.volunteerBadge}
            companyBadge={labels.companyBadge}
          />
          <CommunityFeedback
            client:visible
            contentType="external_link"
            contentId={service.id}
            locale={locale}
            labels={feedbackLabels}
            confidenceLabels={confidenceLabels}
            compact
          />
        </div>
      ))
    }
  </div>
</section>
