---
import { EMERGENCY_ZONES } from "@/data/emergency-zones";
import type { Locale } from "@/i18n/config";

interface Props {
  locale: Locale;
  hashtag: string;
  criticalTitle: string;
  criticalBody: string;
  portals: {
    centers: { title: string; description: string; viewCta: string; registerCta: string };
    delivery: { title: string; description: string; viewCta: string; registerCta: string };
  };
  zonesTitle: string;
  registerPath: string;
  volunteersRegisterPath: string;
}

const {
  locale,
  hashtag,
  criticalTitle,
  criticalBody,
  portals,
  zonesTitle,
  registerPath,
  volunteersRegisterPath,
} = Astro.props;
---

<div class="space-y-10">
  <p class="text-sm font-medium text-ink-secondary">{hashtag}</p>

  <section
    class="rounded-2xl border border-warning/40 bg-warning/10 p-5"
    aria-labelledby="critical-notice-title"
  >
    <div class="flex gap-3">
      <span class="text-xl" aria-hidden="true">⚠️</span>
      <div>
        <h2 id="critical-notice-title" class="text-base font-semibold text-ink">
          {criticalTitle}
        </h2>
        <p class="mt-2 text-sm text-ink-secondary">{criticalBody}</p>
      </div>
    </div>
  </section>

  <div class="grid gap-4 md:grid-cols-2">
    <article class="card flex flex-col p-5 sm:p-6">
      <span class="text-2xl" aria-hidden="true">📦</span>
      <h2 class="mt-3 text-lg font-semibold text-ink">{portals.centers.title}</h2>
      <p class="mt-2 flex-1 text-sm text-ink-secondary">{portals.centers.description}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="#directorio-ayuda" class="btn-primary text-sm">{portals.centers.viewCta}</a>
        <a href={registerPath} class="btn-secondary text-sm">{portals.centers.registerCta}</a>
      </div>
    </article>

    <article class="card flex flex-col p-5 sm:p-6">
      <span class="text-2xl" aria-hidden="true">🏍️</span>
      <h2 class="mt-3 text-lg font-semibold text-ink">{portals.delivery.title}</h2>
      <p class="mt-2 flex-1 text-sm text-ink-secondary">{portals.delivery.description}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="#directorio-ayuda" class="btn-primary text-sm">{portals.delivery.viewCta}</a>
        <a href={volunteersRegisterPath} class="btn-secondary text-sm">
          {portals.delivery.registerCta}
        </a>
      </div>
    </article>
  </div>

  <section>
    <h2 class="text-lg font-semibold text-ink">{zonesTitle}</h2>
    <div class="mt-3 flex flex-wrap gap-2">
      {
        EMERGENCY_ZONES.map((zone) => (
          <a
            href={`#directorio-ayuda?zona=${zone.id}`}
            class="rounded-full border border-border bg-surface-elevated px-3 py-1.5 text-xs font-medium text-ink-secondary transition-colors hover:border-accent/50 hover:text-accent"
          >
            {locale === "es" ? zone.label.es : zone.label.en}
          </a>
        ))
      }
    </div>
  </section>
</div>
