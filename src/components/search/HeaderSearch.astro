---
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";

interface Props {
  locale: Locale;
  compact?: boolean;
}

const { locale, compact = true } = Astro.props;
const { t } = useTranslations(locale);
---

<form
  action={`/${locale}/buscar`}
  method="get"
  role="search"
  class:list={["relative", compact ? "hidden md:block w-full max-w-xs lg:max-w-sm" : "w-full max-w-2xl"]}
>
  <label for="header-search" class="sr-only">{t("search.placeholder")}</label>
  <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-ink-muted" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
  </span>
  <input
    id="header-search"
    type="search"
    name="q"
    placeholder={t("search.placeholderShort")}
    class:list={[
      "input w-full pl-9",
      compact ? "py-1.5 text-sm" : "py-3 text-base",
    ]}
    autocomplete="off"
  />
</form>
