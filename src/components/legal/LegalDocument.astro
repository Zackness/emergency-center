---
export interface LegalSection {
  title: string;
  paragraphs: string[];
  list?: string[];
}

interface Props {
  updatedLabel: string;
  updatedAt: string;
  sections: LegalSection[];
  relatedLinks?: { href: string; label: string }[];
}

const { updatedLabel, updatedAt, sections, relatedLinks } = Astro.props;
---

<article class="container-app pb-16 -mt-4 max-w-3xl">
  <p class="text-sm text-ink-muted mb-8">
    {updatedLabel}: <time datetime="2026-06-26">{updatedAt}</time>
  </p>

  {
    sections.map((section) => (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-ink mb-3">{section.title}</h2>
        {section.paragraphs.map((paragraph) => (
          <p class="text-sm text-ink-secondary mb-3 leading-relaxed">{paragraph}</p>
        ))}
        {section.list && section.list.length > 0 && (
          <ul class="list-disc pl-5 text-sm text-ink-secondary space-y-1.5">
            {section.list.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}
      </section>
    ))
  }

  {
    relatedLinks && relatedLinks.length > 0 && (
      <nav
        class="mt-10 flex flex-wrap gap-4 border-t border-border pt-6 text-sm"
        aria-label="Related legal documents"
      >
        {relatedLinks.map((link) => (
          <a href={link.href} class="font-medium text-accent hover:underline">
            {link.label}
          </a>
        ))}
      </nav>
    )
  }
</article>
