---
import type { Locale } from "@/i18n/config";
import { localePath } from "@/i18n/config";
import type { VzlaAyudaAviso } from "@/lib/vzlayuda/types";

interface Props {
  locale: Locale;
  offers: VzlaAyudaAviso[];
  requests: VzlaAyudaAviso[];
  offerCount: number;
  requestCount: number;
  fetchedAt: string;
  labels: {
    eyebrow: string;
    title: string;
    subtitle: string;
    offersTitle: string;
    offersSubtitle: string;
    requestsTitle: string;
    requestsSubtitle: string;
    offerHint: string;
    requestHint: string;
    viewOffers: string;
    viewRequests: string;
    publishOffer: string;
    publishRequest: string;
    updated: string;
    offerBadge: string;
    requestBadge: string;
    viewAll: string;
  };
}

const { locale, offers, requests, offerCount, requestCount, fetchedAt, labels } = Astro.props;
const voluntariosPath = localePath(locale, "voluntarios");

function locationOf(row: VzlaAyudaAviso) {
  return [row.ciudad, row.estado].filter(Boolean).join(", ");
}

function formatDate(iso: string) {
  try {
    return new Date(iso).toLocaleString(locale === "es" ? "es-VE" : "en-US", {
      dateStyle: "short",
      timeStyle: "short",
    });
  } catch {
    return "";
  }
}
---

<section id="ayuda-solidaria" class="container-app py-12 sm:py-16">
  <div class="mb-8 max-w-3xl">
    <span class="eyebrow mb-3">{labels.eyebrow}</span>
    <h2 class="section-title">{labels.title}</h2>
    <p class="section-subtitle">{labels.subtitle}</p>
    {fetchedAt && (
      <p class="mt-2 text-xs text-ink-muted">
        {labels.updated} {formatDate(fetchedAt)} Ę VZLA Ayuda + local
      </p>
    )}
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <article class="flex flex-col rounded-2xl border-2 border-success/30 bg-success-muted/20 p-5 sm:p-6">
      <div class="mb-4">
        <span class="text-xs font-semibold uppercase tracking-wide text-success">{labels.offerBadge}</span>
        <h3 class="mt-1 text-xl font-semibold text-ink">{labels.offersTitle}</h3>
        <p class="mt-1 text-sm text-ink-secondary">{labels.offersSubtitle}</p>
        <p class="mt-2 text-xs text-ink-muted">{labels.offerHint}</p>
        <p class="mt-3 text-2xl font-bold tabular-nums text-success">{offerCount}</p>
      </div>

      <ul class="mb-5 flex flex-1 flex-col gap-3">
        {offers.length === 0 ? (
          <li class="rounded-xl border border-border bg-surface/60 p-4 text-sm text-ink-secondary">
            Ś
          </li>
        ) : (
          offers.map((row) => (
            <li class="rounded-xl border border-border bg-surface/80 p-4">
              <p class="font-medium text-ink line-clamp-2">{row.titulo}</p>
              {row.descripcion && (
                <p class="mt-1 text-sm text-ink-secondary line-clamp-2">{row.descripcion}</p>
              )}
              <p class="mt-2 text-xs text-ink-muted">
                {row.nombre && <span>{row.nombre}</span>}
                {locationOf(row) && (
                  <span>
                    {row.nombre ? " Ę " : ""}
                    {locationOf(row)}
                  </span>
                )}
              </p>
            </li>
          ))
        )}
      </ul>

      <div class="flex flex-wrap gap-2">
        <a href={`${voluntariosPath}#quiero-ayudar`} class="btn-primary bg-success hover:bg-success/90 text-sm">
          {labels.viewOffers}
        </a>
        <a href={`${voluntariosPath}#publicar-ayuda`} class="btn-secondary text-sm">
          {labels.publishOffer}
        </a>
      </div>
    </article>

    <article class="flex flex-col rounded-2xl border-2 border-emergency/30 bg-emergency-muted/20 p-5 sm:p-6">
      <div class="mb-4">
        <span class="text-xs font-semibold uppercase tracking-wide text-emergency">{labels.requestBadge}</span>
        <h3 class="mt-1 text-xl font-semibold text-ink">{labels.requestsTitle}</h3>
        <p class="mt-1 text-sm text-ink-secondary">{labels.requestsSubtitle}</p>
        <p class="mt-2 text-xs text-ink-muted">{labels.requestHint}</p>
        <p class="mt-3 text-2xl font-bold tabular-nums text-emergency">{requestCount}</p>
      </div>

      <ul class="mb-5 flex flex-1 flex-col gap-3">
        {requests.length === 0 ? (
          <li class="rounded-xl border border-border bg-surface/60 p-4 text-sm text-ink-secondary">
            Ś
          </li>
        ) : (
          requests.map((row) => (
            <li class="rounded-xl border border-border bg-surface/80 p-4">
              <p class="font-medium text-ink line-clamp-2">{row.titulo}</p>
              {row.descripcion && (
                <p class="mt-1 text-sm text-ink-secondary line-clamp-2">{row.descripcion}</p>
              )}
              <p class="mt-2 text-xs text-ink-muted">
                {row.nombre && <span>{row.nombre}</span>}
                {locationOf(row) && (
                  <span>
                    {row.nombre ? " Ę " : ""}
                    {locationOf(row)}
                  </span>
                )}
              </p>
            </li>
          ))
        )}
      </ul>

      <div class="flex flex-wrap gap-2">
        <a href={`${voluntariosPath}#necesito-ayuda`} class="btn-primary bg-emergency hover:bg-emergency/90 text-sm">
          {labels.viewRequests}
        </a>
        <a href={`${voluntariosPath}#publicar-ayuda`} class="btn-secondary text-sm">
          {labels.publishRequest}
        </a>
      </div>
    </article>
  </div>

  <p class="mt-6 text-center">
    <a href={voluntariosPath} class="text-sm font-medium text-accent hover:underline">
      {labels.viewAll} ?
    </a>
  </p>
</section>
