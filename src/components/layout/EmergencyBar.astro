---
import type { Locale } from "@/i18n/config";
import { SEED_EMERGENCY_NUMBERS } from "@/data/seed";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="bg-zinc-900 text-white text-sm border-b border-zinc-800 dark:border-border">
  <div class="container-app flex items-center justify-between gap-4 py-2">
    <div class="flex items-center gap-2 overflow-x-auto scrollbar-none">
      <span class="flex shrink-0 items-center gap-1.5 font-semibold text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-emergency"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{locale === "es" ? "Emergencia:" : "Emergency:"}</span>
      </span>
      {
        SEED_EMERGENCY_NUMBERS.map((num) => (
          <a
            href={`tel:${num.number.replace(/[^0-9+]/g, "")}`}
            class="group flex shrink-0 items-center gap-1.5 rounded-lg bg-white/10 px-2.5 py-1 font-medium tabular-nums transition-colors hover:bg-emergency hover:text-white"
          >
            <span class="text-zinc-300 group-hover:text-white">{locale === "es" ? num.label_es : num.label_en}</span>
            <span class="font-semibold">{num.number}</span>
          </a>
        ))
      }
    </div>
    <span class="hidden shrink-0 items-center gap-2 text-zinc-400 sm:flex">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emergency opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emergency"></span>
      </span>
      {locale === "es" ? "Estado de emergencia activo" : "State of emergency active"}
    </span>
  </div>
</div>
