---
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { PROJECT_CREDITS, PROJECT_IS_OPEN_SOURCE, PROJECT_REPOSITORY_URL } from "@/data/credits";
import { resolveSiteFootprints } from "@/data/site-footprints";
import Logo from "@/components/ui/Logo.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { t } = useTranslations(locale);
const footprints = resolveSiteFootprints(locale, t);
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface-muted mt-16">
  <div class="container-app py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2.5 mb-4">
          <Logo size={36} />
          <span class="font-semibold text-ink">Emergency Center</span>
        </div>
        <p class="text-sm text-ink-secondary max-w-md">
          {t("footer.disclaimer")}
        </p>
        <div class="mt-5">
          <h3 class="text-xs font-semibold uppercase tracking-wide text-ink-muted mb-2">
            {t("footer.creditsTitle")}
          </h3>
          <ul class="space-y-1.5 text-sm text-ink-secondary">
            {
              PROJECT_CREDITS.map((credit) => (
                <li>
                  <a
                    href={credit.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-ink"
                  >
                    {credit.name}
                  </a>
                  <span class="text-ink-muted"> — </span>
                  <a
                    href={credit.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-ink-muted hover:text-accent"
                  >
                    {credit.displayUrl}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        {
          PROJECT_IS_OPEN_SOURCE && (
            <div class="mt-5 rounded-2xl border border-success/25 bg-success-muted/30 p-4 max-w-md">
              <span class="badge bg-success-muted text-success text-xs">{t("footer.openSourceBadge")}</span>
              <p class="mt-2 text-sm text-ink-secondary">{t("footer.openSource")}</p>
              {
                PROJECT_REPOSITORY_URL && (
                  <a
                    href={PROJECT_REPOSITORY_URL}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-2 inline-flex text-xs font-medium text-accent hover:underline"
                  >
                    {t("footer.openSourceLink")} →
                  </a>
                )
              }
            </div>
          )
        }
      </div>
      <div>
        <h3 class="font-medium text-ink mb-3">
          {t("home.footprints.title")}
        </h3>
        <ul class="space-y-2 text-sm text-ink-secondary columns-1 sm:columns-2 gap-x-6">
          {
            footprints.map((item) => (
              <li class="break-inside-avoid">
                <a href={item.href} class="hover:text-ink">
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="font-medium text-ink mb-3">
          {t("footer.legalTitle")}
        </h3>
        <ul class="space-y-2 text-sm text-ink-secondary">
          <li><a href={`/${locale}/privacidad`} class="hover:text-ink">{t("footer.privacy")}</a></li>
          <li><a href={`/${locale}/terminos`} class="hover:text-ink">{t("footer.terms")}</a></li>
          <li><a href="/admin" class="hover:text-ink">{t("nav.admin")}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-border pt-8 text-sm text-ink-muted">
      <p>
        © {year} Emergency Center — {t("footer.madeBy")}{" "}
        {
          PROJECT_CREDITS.map((credit, index) => (
            <>
              {index > 0 && (index === PROJECT_CREDITS.length - 1 ? ` ${t("footer.and")} ` : ", ")}
              <a
                href={credit.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-ink"
              >
                {credit.name}
              </a>
            </>
          ))
        }
      </p>
      <p class="text-xs text-center sm:text-right">
        {PROJECT_IS_OPEN_SOURCE && (
          <span class="badge bg-success-muted text-success mr-2">{t("footer.openSourceBadge")}</span>
        )}
        {t("meta.tagline")}
      </p>
    </div>
  </div>
</footer>
