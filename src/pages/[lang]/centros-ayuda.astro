---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import DonationNeedsList from "@/components/ui/DonationNeedsList.astro";
import HelpCenterGallery from "@/components/ui/HelpCenterGallery.astro";
import MapView from "@/components/map/MapView";
import CommunityFeedback from "@/components/community/CommunityFeedback";
import { isValidLocale, type Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { fetchHelpCenters } from "@/lib/data";
import { getHelpCenterImages } from "@/lib/help-centers";
import type { MapLocation } from "@/types";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect("/es/centros-ayuda");

const locale = lang as Locale;
const { t, dict } = useTranslations(locale);
const centers = await fetchHelpCenters();
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;

const mapLocations: MapLocation[] = centers.map((c) => ({
  id: c.id,
  name: c.name,
  latitude: c.latitude,
  longitude: c.longitude,
  type: "help_center" as const,
  address: c.address,
}));
---

<BaseLayout locale={locale} title={t("helpCenters.title")}>
  <PageHeader title={t("helpCenters.title")} subtitle={t("helpCenters.subtitle")} imageSrc="/images/headers/ayuda-comunitaria.svg" imageAlt="">
    <section class="mb-6 rounded-2xl border border-accent/30 bg-surface-muted p-5">
      <h2 class="text-lg font-semibold text-ink">{t("centerDashboard.banner.title")}</h2>
      <p class="mt-2 text-sm text-ink-secondary">{t("centerDashboard.banner.description")}</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={`/${locale}/centros-ayuda/registrar`} class="btn-primary">
          {t("centerDashboard.banner.registerCta")}
        </a>
        <a href={`/${locale}/centros-ayuda/panel`} class="btn-secondary">
          {t("centerDashboard.banner.panelCta")}
        </a>
        <a href={`/${locale}/centros-ayuda/registrar?mode=third_party`} class="btn-secondary">
          {t("helpCenters.register.ctaThird")}
        </a>
        <a href={`/${locale}/voluntarios`} class="btn-secondary">
          {t("centerDashboard.banner.volunteerCta")}
        </a>
      </div>
    </section>

    <section class="mb-6 rounded-2xl border border-accent/20 bg-accent-muted/40 p-5" id="logistica-gratis">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
            {t("helpCenters.logistics.badge")}
          </p>
          <h2 class="mt-1 text-lg font-semibold text-ink">
            {t("helpCenters.logistics.title")}
          </h2>
          <p class="mt-2 text-sm text-ink-secondary">
            {t("helpCenters.logistics.description")}
          </p>
        </div>
        <span class="badge bg-white text-accent shadow-soft">
          {t("helpCenters.logistics.free")}
        </span>
      </div>
      <CommunityFeedback
        client:visible
        contentType="external_link"
        contentId="help-centers-logistics"
        locale={locale}
        labels={feedbackLabels}
        confidenceLabels={confidenceLabels}
        compact
      />
    </section>

    <DonationNeedsList
      locale={locale}
      feedbackLabels={feedbackLabels}
      confidenceLabels={confidenceLabels}
    />

    <div class="mb-8">
      <MapView client:only="react" locations={mapLocations} locale={locale} height="450px" />
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {
        centers.map((center) => (
          <article class="card flex flex-col" id={center.id}>
            <HelpCenterGallery
              images={getHelpCenterImages(center)}
              alt={center.name}
            />
            <div class="flex flex-1 flex-col">
              <div class="flex items-center gap-2 flex-wrap">
                <h3 class="font-semibold text-ink">{center.name}</h3>
                {center.is_verified && (
                  <span class="badge-verified">{t("common.verified")}</span>
                )}
                <span class="badge bg-surface-muted text-ink-secondary">
                  {t(`helpCenters.types.${center.type}` as "helpCenters.types.church")}
                </span>
              </div>
              {center.description && (
                <p class="mt-2 text-sm text-ink-secondary">{center.description}</p>
              )}
              <div class="mt-3 flex flex-col gap-1 text-sm text-ink-secondary">
                <span>{center.city}, {center.state}</span>
                <span>{center.address}</span>
                {center.phone && (
                  <a href={`tel:${center.phone.replace(/[^0-9+]/g, "")}`} class="text-accent hover:underline">
                    {t("common.phone")}: {center.phone}
                  </a>
                )}
                {center.schedule && (
                  <span>{t("common.schedule")}: {center.schedule}</span>
                )}
              </div>
              {center.accepts?.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {center.accepts.map((item: string) => (
                    <span class="badge bg-accent-muted text-accent text-xs">
                      {t(`helpCenters.accepts.${item}` as "helpCenters.accepts.water")}
                    </span>
                  ))}
                </div>
              )}
              <a
                href={`https://www.google.com/maps/dir/?api=1&destination=${center.latitude},${center.longitude}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary mt-4 self-start text-xs"
              >
                {t("common.directions")}
              </a>
              <CommunityFeedback
                client:visible
                contentType="help_center"
                contentId={center.id}
                locale={locale}
                labels={feedbackLabels}
                confidenceLabels={confidenceLabels}
                compact
              />
            </div>
          </article>
        ))
      }
    </div>
  </PageHeader>
</BaseLayout>
