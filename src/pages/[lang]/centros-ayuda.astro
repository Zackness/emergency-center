---
import CentrosAyudaPage from "@/views/CentrosAyudaPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/centros-ayuda");
if (locale instanceof Response) return locale;
---

<CentrosAyudaPage locale={locale} />
