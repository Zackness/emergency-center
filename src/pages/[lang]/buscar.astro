---
import BuscarPage from "@/views/BuscarPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/buscar");
if (locale instanceof Response) return locale;
---

<BuscarPage locale={locale} />
