---
export const prerender = false;

import MascotasPage from "@/views/MascotasPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/mascotas");
if (locale instanceof Response) return locale;
---

<MascotasPage locale={locale} />
