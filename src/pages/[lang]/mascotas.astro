---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import ExternalLinkCard from "@/components/ui/ExternalLinkCard.astro";
import PetVetAidCard from "@/components/ui/PetVetAidCard.astro";
import SocialRegistryCard from "@/components/ui/SocialRegistryCard.astro";
import MissingPetRegistry from "@/components/registry/MissingPetRegistry";
import CommunityFeedback from "@/components/community/CommunityFeedback";
import { getPetVeterinaryAid } from "@/data/pet-veterinary-aid";
import { getSocialRegistries } from "@/data/social-registries";
import { VENEZUELA_STATES } from "@/data/seed";
import { isValidLocale, type Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { fetchExternalLinks } from "@/lib/data";
import { fetchMissingPetsStats } from "@/lib/missing-pets/feed";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect("/es/mascotas");

const locale = lang as Locale;
const { t, dict } = useTranslations(locale);
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;

let stats = { total: 0, lost: 0, found: 0, last_synced_at: null as string | null };
try {
  stats = await fetchMissingPetsStats();
} catch (err) {
  console.error("[mascotas] failed to load HuellasCAN stats:", err);
}

const petLinks = await fetchExternalLinks("pets");
const leguauRegistry = getSocialRegistries("pets").find((r) => r.slug === "academia-leguau");
const vetcity = getPetVeterinaryAid("vetcity-maracay")[0];
const leguau = dict.pets.academiaLeguau;
const vetcityCopy = dict.pets.vetcity;

const registryLabels = {
  ...dict.pets.registry,
  noResults: t("common.noResults"),
};

const leguauWhatsappUrl = `https://wa.me/584241596590?text=${encodeURIComponent(
  locale === "es"
    ? "Hola, perdí a mi mascota en el terremoto. Adjunto foto y datos: nombre, especie, sexo, raza, ubicación, edad, colores/señas y mi contacto."
    : "Hello, I lost my pet in the earthquake. Photo and details attached: name, species, sex, breed, location, age, colors/markings and my contact."
)}`;

const vetcityWhatsappUrl = `https://wa.me/${vetcity.phone_intl}?text=${encodeURIComponent(
  locale === "es"
    ? "Hola, mi mascota se vio afectada por el terremoto y necesito atención médica solidaria."
    : "Hello, my pet was affected by the earthquake and I need solidarity medical care."
)}`;

const fallbackPlatforms = [
  {
    id: "pet-huellascan",
    title: t("pets.platforms.huellascan.name"),
    description: t("pets.platforms.huellascan.desc"),
    url: "https://www.huellascan.com/terremoto",
    verified: false,
  },
  {
    id: "pet-mascotas-perdidas-venezuela",
    title: locale === "es" ? "Mascotas Perdidas Venezuela" : "Lost Pets Venezuela",
    description:
      locale === "es"
        ? "Plataforma comunitaria para reportar mascotas perdidas durante emergencias"
        : "Community platform to report pets lost during emergencies",
    url: "https://mascotasperdidasvenezuela.org",
    verified: false,
  },
];

const HUELLASCAN_URL = "https://www.huellascan.com/terremoto";
const huellascanName = t("pets.platforms.huellascan.name");
const huellascanDesc = t("pets.platforms.huellascan.desc");
const huellascanTags: string[] =
  locale === "es"
    ? ["Sin registro", "Gratis", "Perros y gatos", "Reunificación tras el sismo"]
    : ["No sign-up", "Free", "Dogs & cats", "Post-quake reunification"];
const huellascanCta = locale === "es" ? "Buscar mi mascota en HuellasCAN" : "Search for my pet on HuellasCAN";
const huellascanEyebrow = locale === "es" ? "Encuentra tu mascota" : "Find your pet";

const allPlatforms =
  petLinks.length > 0
    ? petLinks.map((link) => ({
        id: link.id,
        title: link.title,
        description: link.description ?? "",
        url: link.url,
        verified: link.is_verified,
      }))
    : fallbackPlatforms;

const platforms = allPlatforms.filter((p) => !p.url.includes("huellascan"));

const syncedLabel = stats.last_synced_at
  ? new Date(stats.last_synced_at).toLocaleString(locale === "es" ? "es-VE" : "en-US", {
      dateStyle: "short",
      timeStyle: "short",
    })
  : null;
---

<BaseLayout locale={locale} title={t("pets.title")}>
  <PageHeader title={t("pets.title")} subtitle={t("pets.subtitle")} imageSrc="/images/headers/salud-rescate.svg" imageAlt="">
  </PageHeader>

  <div class="container-app pb-16 space-y-16 -mt-4">
    <section class="max-w-3xl">
      <div class="rounded-2xl border border-border bg-surface-muted p-4 text-sm text-ink-secondary">
        {t("pets.disclaimer")}
      </div>
    </section>

    <section
      id="huellascan"
      class="overflow-hidden rounded-3xl border-2 border-accent/40 bg-gradient-to-br from-accent/10 via-surface to-surface shadow-sm"
    >
      <div class="p-6 sm:p-8">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
          <div
            class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-accent/15 text-accent"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="11" cy="4" r="2" />
              <circle cx="18" cy="8" r="2" />
              <circle cx="20" cy="16" r="2" />
              <ellipse cx="9" cy="15" rx="4" ry="5" />
              <circle cx="4" cy="9" r="2" />
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-xs font-semibold uppercase tracking-wide text-accent">{huellascanEyebrow}</p>
            <h2 class="mt-1 text-xl font-bold text-ink sm:text-2xl">{huellascanName}</h2>
            <p class="mt-2 text-sm text-ink-secondary sm:text-base">{huellascanDesc}</p>

            <ul class="mt-4 flex flex-wrap gap-2">
              {
                huellascanTags.map((tag) => (
                  <li class="rounded-full bg-surface-muted px-3 py-1 text-xs font-medium text-ink-secondary">
                    {tag}
                  </li>
                ))
              }
            </ul>

            <a
              href={HUELLASCAN_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary mt-5 inline-flex items-center gap-2"
            >
              {huellascanCta}
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 17 7" />
                <path d="M7 7h10v10" />
              </svg>
            </a>

            <div class="mt-5 border-t border-border/60 pt-4">
              <CommunityFeedback
                client:visible
                contentType="external_link"
                contentId="pet-huellascan"
                locale={locale}
                labels={feedbackLabels}
                confidenceLabels={confidenceLabels}
                compact
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="registro-huellascan">
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-ink">{t("pets.registry.title")}</h2>
        <p class="mt-1 max-w-3xl text-sm text-ink-secondary">{t("pets.registry.subtitle")}</p>
      </div>

      <div class="mb-6 grid max-w-4xl gap-4 sm:grid-cols-3">
        <div class="card flex flex-col items-center justify-center border-emergency/30 bg-emergency-muted/20 py-8 text-center">
          <p class="text-5xl font-extrabold tracking-tight text-emergency">{stats.lost.toLocaleString()}</p>
          <p class="mt-2 text-sm font-medium text-ink-secondary">{t("pets.registry.statsLost")}</p>
        </div>
        <div class="card flex flex-col items-center justify-center border-accent/30 bg-accent-muted/20 py-8 text-center">
          <p class="text-5xl font-extrabold tracking-tight text-accent">{stats.found.toLocaleString()}</p>
          <p class="mt-2 text-sm font-medium text-ink-secondary">{t("pets.registry.statsFound")}</p>
        </div>
        <div class="card flex flex-col items-center justify-center py-8 text-center">
          <p class="text-5xl font-extrabold tracking-tight text-ink">{stats.total.toLocaleString()}</p>
          <p class="mt-2 text-sm font-medium text-ink-secondary">{t("pets.registry.statsTotal")}</p>
        </div>
      </div>

      {
        syncedLabel && (
          <p class="mb-6 max-w-3xl text-xs text-ink-muted">
            {t("pets.registry.lastSynced")}: {syncedLabel}
          </p>
        )
      }

      <MissingPetRegistry
        client:load
        locale={locale}
        states={VENEZUELA_STATES}
        labels={registryLabels}
        initialStats={stats}
      />
    </section>

    {
      leguauRegistry && (
        <section>
          <SocialRegistryCard
            anchorId="academia-leguau"
            imageUrl={leguauRegistry.image_url}
            title={leguau.title}
            subtitle={leguau.subtitle}
            body={leguau.body}
            channelLabel={leguau.channelLabel}
            instagramLabel={leguau.instagramLabel}
            instagramUrl={leguauRegistry.instagram_url}
            handle={leguauRegistry.handle}
            whatsappLabel={leguau.whatsappLabel}
            whatsappUrl={leguauWhatsappUrl}
            phoneDisplay={leguauRegistry.whatsapp}
            fieldsLabel={leguau.fieldsLabel}
            fields={leguau.fields}
            notWebsiteNote={leguau.notWebsiteNote}
          >
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId="academia-leguau"
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </SocialRegistryCard>
        </section>
      )
    }

    <section>
      <h2 class="mb-4 text-lg font-semibold text-ink">{vetcityCopy.sectionTitle}</h2>
      <PetVetAidCard
        anchorId="vetcity-maracay"
        imageUrl={vetcity.image_url}
        title={vetcityCopy.title}
        subtitle={vetcityCopy.subtitle}
        body={vetcityCopy.body}
        channelLabel={vetcityCopy.channelLabel}
        locationLabel={vetcityCopy.locationLabel}
        location={`${vetcity.city}, ${vetcity.state}`}
        instagramLabel={vetcityCopy.instagramLabel}
        instagramUrl={vetcity.instagram_url}
        handle={vetcity.handle}
        phoneLabel={vetcityCopy.phoneLabel}
        phone={vetcity.phone}
        whatsappLabel={vetcityCopy.whatsappLabel}
        whatsappUrl={vetcityWhatsappUrl}
      >
        <CommunityFeedback
          client:visible
          contentType="external_link"
          contentId="vetcity-maracay"
          locale={locale}
          labels={feedbackLabels}
          confidenceLabels={confidenceLabels}
          compact
        />
      </PetVetAidCard>
    </section>

    <section>
      <h2 class="mb-4 text-lg font-semibold text-ink">{t("pets.otherPlatforms")}</h2>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {
          platforms.map((platform) => (
            <ExternalLinkCard
              title={platform.title}
              description={platform.description}
              url={platform.url}
              verified={platform.verified}
              verifiedLabel={t("common.verified")}
            >
              <CommunityFeedback
                client:visible
                contentType="external_link"
                contentId={platform.id}
                locale={locale}
                labels={feedbackLabels}
                confidenceLabels={confidenceLabels}
                compact
              />
            </ExternalLinkCard>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
