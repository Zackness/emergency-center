---
import DesaparecidosPage from "@/views/DesaparecidosPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/desaparecidos");
if (locale instanceof Response) return locale;
---

<DesaparecidosPage locale={locale} />
