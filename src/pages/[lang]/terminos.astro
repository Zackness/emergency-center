---
import TerminosPage from "@/views/TerminosPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/terminos");
if (locale instanceof Response) return locale;
---

<TerminosPage locale={locale} />
