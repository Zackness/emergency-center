---
import NoticiasPage from "@/views/NoticiasPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/noticias");
if (locale instanceof Response) return locale;
---

<NoticiasPage locale={locale} />
