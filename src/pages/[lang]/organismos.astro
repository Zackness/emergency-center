---
import OrganismosPage from "@/views/OrganismosPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/organismos");
if (locale instanceof Response) return locale;
---

<OrganismosPage locale={locale} />
