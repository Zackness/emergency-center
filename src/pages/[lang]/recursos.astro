---
import RecursosPage from "@/views/RecursosPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/recursos");
if (locale instanceof Response) return locale;
---

<RecursosPage locale={locale} />
