---
import VoluntariosPage from "@/views/VoluntariosPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/voluntarios");
if (locale instanceof Response) return locale;
---

<VoluntariosPage locale={locale} />
