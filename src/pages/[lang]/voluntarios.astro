---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import RescuerCallCard from "@/components/ui/RescuerCallCard.astro";
import VolunteerGroupCard from "@/components/ui/VolunteerGroupCard.astro";
import VolunteerRegistryCard from "@/components/ui/VolunteerRegistryCard.astro";
import VolunteerForm from "@/components/forms/VolunteerForm";
import { INTERPRETER_VOLUNTEER_GROUP } from "@/data/interpreter-volunteer-group";
import { RED_CROSS_VOLUNTEER_REGISTRY } from "@/data/red-cross-volunteer";
import { CALIPSO_VOLUNTEER_LODGING } from "@/data/volunteer-lodging";
import {
  ACARIGUA_TRANSPORT_VOLUNTEER_CALL,
  BARQUISIMETO_CARGO_TRANSPORT_CALL,
  LARA_TRANSPORT_VOLUNTEER_CALL,
  MEDICAL_VOLUNTEER_CALL,
  RESCUER_VOLUNTEER_CALL,
  UNEFM_TUCACAS_VOLUNTEER_CALL,
} from "@/data/volunteer-calls";
import { isValidLocale, type Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { fetchHelpCenters } from "@/lib/data";
import { VENEZUELA_STATES } from "@/data/seed";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect("/es/voluntarios");

const locale = lang as Locale;
const { t, dict } = useTranslations(locale);
const helpCenters = await fetchHelpCenters();
const rescuerCall = dict.volunteers.rescuerCall;
const acariguaCall = dict.volunteers.acariguaTransportCall;
const cargoCall = dict.volunteers.cargoTransportCall;
const laraCall = dict.volunteers.laraTransportCall;
const medicalCall = dict.volunteers.medicalCall;
const unefmCall = dict.volunteers.unefmTucacasCall;
const redCrossCall = dict.volunteers.redCrossCall;
const interpretersCall = dict.volunteers.interpretersCall;
const formLabels = {
  ...dict.volunteers.form,
  submit: t("common.submit"),
};

const medicalMessage =
  locale === "es"
    ? "Hola%20Dr.%20Hector%2C%20soy%20parte%20del%20personal%20medico%20o%20estudiante%20de%20medicina%20y%20quiero%20apoyar%20en%20el%20equipo%20que%20viajara%20a%20Caracas."
    : "Hello%20Dr.%20Hector%2C%20I%20am%20medical%20staff%20or%20a%20medical%20student%20and%20want%20to%20support%20the%20team%20traveling%20to%20Caracas.";
const rescuerMessage =
  locale === "es"
    ? "Hola%2C%20soy%20rescatista%20o%20defensa%20civil%20y%20quiero%20apoyar%20en%20Caracas%20o%20La%20Guaira.%20Necesito%20informacion%20sobre%20el%20traslado."
    : "Hello%2C%20I%20am%20a%20rescuer%20or%20civil%20defense%20member%20and%20want%20to%20help%20in%20Caracas%20or%20La%20Guaira.%20I%20need%20information%20about%20transportation.";
const laraMessage =
  locale === "es"
    ? "Hola%2C%20soy%20personal%20de%20emergencia%20en%20Lara%20y%20quiero%20apoyar%20en%20Caracas.%20Necesito%20informacion%20sobre%20el%20traslado%20gratuito."
    : "Hello%2C%20I%20am%20emergency%20personnel%20in%20Lara%20and%20want%20to%20support%20in%20Caracas.%20I%20need%20information%20about%20free%20transportation.";
const acariguaMessage =
  locale === "es"
    ? "Hola%2C%20puedo%20ofrecer%20transporte%20desde%20Acarigua%20hacia%20La%20Guaira%20para%20el%20equipo%20de%20enfermeria."
    : "Hello%2C%20I%20can%20offer%20transportation%20from%20Acarigua%20to%20La%20Guaira%20for%20the%20nursing%20team.";
const cargoMessage =
  locale === "es"
    ? "Hola%2C%20necesito%20una%20carrera%20para%20llevar%20insumos%20a%20un%20centro%20de%20acopio%20en%20Barquisimeto."
    : "Hello%2C%20I%20need%20a%20ride%20to%20take%20supplies%20to%20a%20collection%20center%20in%20Barquisimeto.";

const medicalWhatsappUrl = `https://wa.me/${MEDICAL_VOLUNTEER_CALL.whatsapp}?text=${medicalMessage}`;
const rescuerWhatsappUrl = `https://wa.me/${RESCUER_VOLUNTEER_CALL.whatsapp}?text=${rescuerMessage}`;
const laraWhatsappUrl = `https://wa.me/${LARA_TRANSPORT_VOLUNTEER_CALL.whatsapp}?text=${laraMessage}`;
const acariguaWhatsappUrl = `https://wa.me/${ACARIGUA_TRANSPORT_VOLUNTEER_CALL.whatsapp}?text=${acariguaMessage}`;
const cargoWhatsappUrl = `https://wa.me/${BARQUISIMETO_CARGO_TRANSPORT_CALL.whatsapp}?text=${cargoMessage}`;
---

<BaseLayout locale={locale} title={t("volunteers.title")}>
  <PageHeader title={t("volunteers.title")} subtitle={t("volunteers.subtitle")}>
    <section class="mb-8 rounded-2xl border border-accent/20 bg-accent-muted/40 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
        {t("volunteers.lodging.badge")}
      </p>
      <h2 class="mt-1 text-lg font-semibold text-ink">{t("volunteers.lodging.title")}</h2>
      <p class="mt-2 text-sm text-ink-secondary">{t("volunteers.lodging.description")}</p>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <a href={CALIPSO_VOLUNTEER_LODGING.phoneTel} class="btn-primary text-sm">
          {t("volunteers.lodging.call")}: {CALIPSO_VOLUNTEER_LODGING.phone}
        </a>
        <a
          href={CALIPSO_VOLUNTEER_LODGING.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary text-sm"
        >
          {CALIPSO_VOLUNTEER_LODGING.instagramHandle}
        </a>
        <a
          href={`/${locale}/refugios#${CALIPSO_VOLUNTEER_LODGING.id}`}
          class="text-sm text-accent hover:underline"
        >
          {t("volunteers.lodging.cta")}
        </a>
      </div>
    </section>

    <VolunteerRegistryCard
      anchorId="cruz-roja-voluntarios"
      organization={RED_CROSS_VOLUNTEER_REGISTRY.organization}
      title={redCrossCall.title}
      body={redCrossCall.body}
      priorityLabel={redCrossCall.priorityLabel}
      priorityText={redCrossCall.priorityText}
      registerLabel={redCrossCall.register}
      registerUrl={RED_CROSS_VOLUNTEER_REGISTRY.registerUrl}
      displayUrl={RED_CROSS_VOLUNTEER_REGISTRY.displayUrl}
      shareLabel={redCrossCall.share}
      verifiedLabel={t("common.verified")}
    />

    <VolunteerGroupCard
      anchorId="interpretes-idiomas"
      badge={interpretersCall.badge}
      title={interpretersCall.title}
      body={interpretersCall.body}
      priorityLabel={interpretersCall.priorityLabel}
      priorityText={interpretersCall.priorityText}
      joinLabel={interpretersCall.joinLabel}
      joinUrl={INTERPRETER_VOLUNTEER_GROUP.whatsappGroupUrl}
      displayPath={INTERPRETER_VOLUNTEER_GROUP.displayPath}
      shareLabel={interpretersCall.share}
      imageUrl={INTERPRETER_VOLUNTEER_GROUP.imageUrl}
      linkNote={interpretersCall.linkNote}
    />

    <RescuerCallCard
      anchorId="equipo-medico"
      imageUrl={MEDICAL_VOLUNTEER_CALL.image_url}
      title={medicalCall.title}
      subtitle={medicalCall.subtitle}
      body={medicalCall.body}
      urgency={medicalCall.urgency}
      phone={MEDICAL_VOLUNTEER_CALL.phone}
      phoneLabel={medicalCall.phoneLabel}
      whatsappLabel={medicalCall.whatsappLabel}
      whatsappUrl={medicalWhatsappUrl}
      shareLabel={medicalCall.share}
      targetLabel={medicalCall.targetLabel}
      targetRegions={medicalCall.targetRegions}
      deployLabel={medicalCall.deployLabel}
      deployRegions={medicalCall.deployRegions}
      offerLabel={medicalCall.offerLabel}
      offerText={medicalCall.offerText}
    />

    <RescuerCallCard
      anchorId="unefm-tucacas"
      imageUrl={UNEFM_TUCACAS_VOLUNTEER_CALL.image_url}
      title={unefmCall.title}
      subtitle={unefmCall.subtitle}
      body={unefmCall.body}
      urgency={unefmCall.urgency}
      shareLabel={unefmCall.share}
      targetLabel={unefmCall.targetLabel}
      targetRegions={unefmCall.targetRegions}
      deployLabel={unefmCall.deployLabel}
      deployRegions={unefmCall.deployRegions}
      offerLabel={unefmCall.offerLabel}
      offerText={unefmCall.offerText}
    />

    <RescuerCallCard
      anchorId="acarigua-transporte"
      imageUrl={ACARIGUA_TRANSPORT_VOLUNTEER_CALL.image_url}
      title={acariguaCall.title}
      subtitle={acariguaCall.subtitle}
      body={acariguaCall.body}
      urgency={acariguaCall.urgency}
      phone={ACARIGUA_TRANSPORT_VOLUNTEER_CALL.phone}
      phoneLabel={acariguaCall.phoneLabel}
      whatsappLabel={acariguaCall.whatsappLabel}
      whatsappUrl={acariguaWhatsappUrl}
      shareLabel={acariguaCall.share}
      targetLabel={acariguaCall.targetLabel}
      targetRegions={acariguaCall.targetRegions}
      deployLabel={acariguaCall.deployLabel}
      deployRegions={acariguaCall.deployRegions}
      offerLabel={acariguaCall.offerLabel}
      offerText={acariguaCall.offerText}
    />

    <RescuerCallCard
      anchorId="carreras-gratis-acopio"
      imageUrl={BARQUISIMETO_CARGO_TRANSPORT_CALL.image_url}
      title={cargoCall.title}
      subtitle={cargoCall.subtitle}
      body={cargoCall.body}
      urgency={cargoCall.urgency}
      phone={BARQUISIMETO_CARGO_TRANSPORT_CALL.phone}
      phoneLabel={cargoCall.phoneLabel}
      whatsappLabel={cargoCall.whatsappLabel}
      whatsappUrl={cargoWhatsappUrl}
      shareLabel={cargoCall.share}
      targetLabel={cargoCall.targetLabel}
      targetRegions={cargoCall.targetRegions}
      deployLabel={cargoCall.deployLabel}
      deployRegions={cargoCall.deployRegions}
      offerLabel={cargoCall.offerLabel}
      offerText={cargoCall.offerText}
    />

    <RescuerCallCard
      anchorId="lara-transporte"
      imageUrl={LARA_TRANSPORT_VOLUNTEER_CALL.image_url}
      title={laraCall.title}
      subtitle={laraCall.subtitle}
      body={laraCall.body}
      urgency={laraCall.urgency}
      phone={LARA_TRANSPORT_VOLUNTEER_CALL.phone}
      phoneLabel={laraCall.phoneLabel}
      whatsappLabel={laraCall.whatsappLabel}
      whatsappUrl={laraWhatsappUrl}
      shareLabel={laraCall.share}
      targetLabel={laraCall.targetLabel}
      targetRegions={laraCall.targetRegions}
      deployLabel={laraCall.deployLabel}
      deployRegions={laraCall.deployRegions}
      offerLabel={laraCall.offerLabel}
      offerText={laraCall.offerText}
    />

    <RescuerCallCard
      anchorId="rescatistas"
      imageUrl={RESCUER_VOLUNTEER_CALL.image_url}
      title={rescuerCall.title}
      subtitle={rescuerCall.subtitle}
      body={rescuerCall.body}
      urgency={rescuerCall.urgency}
      phone={RESCUER_VOLUNTEER_CALL.phone}
      phoneLabel={rescuerCall.phoneLabel}
      whatsappLabel={rescuerCall.whatsappLabel}
      whatsappUrl={rescuerWhatsappUrl}
      shareLabel={rescuerCall.share}
      targetLabel={rescuerCall.targetLabel}
      targetRegions={rescuerCall.targetRegions}
      deployLabel={rescuerCall.deployLabel}
      deployRegions={rescuerCall.deployRegions}
      offerLabel={rescuerCall.offerLabel}
      offerText={rescuerCall.offerText}
    />

    <div class="mb-6">
      <h2 class="text-lg font-semibold text-ink">{rescuerCall.formTitle}</h2>
      <p class="mt-1 text-sm text-ink-secondary">{rescuerCall.formSubtitle}</p>
    </div>

    <VolunteerForm
      client:load
      locale={locale}
      labels={formLabels}
      states={VENEZUELA_STATES}
      helpCenters={helpCenters.map((c) => ({
        id: c.id,
        name: c.name,
        city: c.city,
        state: c.state,
      }))}
    />
  </PageHeader>
</BaseLayout>
