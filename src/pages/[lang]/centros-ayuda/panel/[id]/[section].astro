---
export const prerender = false;

import CentrosAyudaPanelCenterPage from "@/views/CentrosAyudaPanelCenterPage.astro";
import type { Locale } from "@/i18n/config";
import {
  centerSectionPath,
  DEFAULT_CENTER_SECTION,
  isCenterSection,
  resolveCenterManagePage,
} from "@/lib/center-manage-page";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const { id, section: sectionParam } = Astro.params;
const localeResult = resolveSecondaryLocale(Astro, "/centros-ayuda/panel");
if (localeResult instanceof Response) return localeResult;

const locale = localeResult as Locale;
const ctx = await resolveCenterManagePage(Astro, locale, id);
if (ctx.redirect) return ctx.redirect;

if (!isCenterSection(sectionParam)) {
  return Astro.redirect(centerSectionPath(locale, ctx.centerId, DEFAULT_CENTER_SECTION));
}

const section = sectionParam;
---

<CentrosAyudaPanelCenterPage
  locale={locale}
  centerId={ctx.centerId}
  userEmail={ctx.user.email ?? ""}
  centerName={ctx.centerName}
  section={section}
/>
