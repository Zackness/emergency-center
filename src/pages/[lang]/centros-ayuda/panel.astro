---
export const prerender = false;

import CentrosAyudaPanelPage from "@/views/CentrosAyudaPanelPage.astro";
import type { Locale } from "@/i18n/config";
import { requireCoordinatorSession } from "@/lib/auth-center";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const localeResult = resolveSecondaryLocale(Astro, "/centros-ayuda/panel");
if (localeResult instanceof Response) return localeResult;

const session = await requireCoordinatorSession(Astro);
if (session.redirect) return session.redirect;

const locale = localeResult as Locale;
---

<CentrosAyudaPanelPage locale={locale} userEmail={session.user!.email ?? ""} />
