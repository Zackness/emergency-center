---
export const prerender = false;

import CentrosAyudaAccesoPage from "@/views/CentrosAyudaAccesoPage.astro";
import type { Locale } from "@/i18n/config";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const localeResult = resolveSecondaryLocale(Astro, "/centros-ayuda/acceso");
if (localeResult instanceof Response) return localeResult;

const locale = localeResult as Locale;
---

<CentrosAyudaAccesoPage locale={locale} />
