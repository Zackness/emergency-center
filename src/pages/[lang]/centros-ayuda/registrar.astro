---
export const prerender = false;

import CentrosAyudaRegistrarPage from "@/views/CentrosAyudaRegistrarPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/centros-ayuda/registrar");
if (locale instanceof Response) return locale;
---

<CentrosAyudaRegistrarPage locale={locale} />
