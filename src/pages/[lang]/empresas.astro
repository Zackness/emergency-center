---
import EmpresasPage from "@/views/EmpresasPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/empresas");
if (locale instanceof Response) return locale;
---

<EmpresasPage locale={locale} />
