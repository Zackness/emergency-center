---
import DanosPage from "@/views/DanosPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/danos");
if (locale instanceof Response) return locale;
---

<DanosPage locale={locale} />
