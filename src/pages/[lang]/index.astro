---
export const prerender = false;

import HomePage from "@/views/HomePage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/");
if (locale instanceof Response) return locale;
---

<HomePage locale={locale} />
