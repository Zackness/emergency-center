---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteFootprints from "@/components/home/SiteFootprints.astro";
import StatCard from "@/components/ui/StatCard.astro";
import GlobalSearch from "@/components/search/GlobalSearch";
import AlliedPlatforms from "@/components/ui/AlliedPlatforms.astro";
import CommunityFeedback from "@/components/community/CommunityFeedback";
import { isValidLocale, type Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import { buildSearchIndex } from "@/lib/search";
import {
  SEED_HELP_CENTERS,
  SEED_HOSPITALS,
  SEED_SHELTERS,
} from "@/data/seed";
import type { SearchResultType } from "@/types/search";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect("/es");

const locale = lang as Locale;
const { t, dict } = useTranslations(locale);
const { confidence: confidenceLabels, ...feedbackLabels } = dict.communityFeedback;
const searchIndex = await buildSearchIndex(locale);
const categoryLabels = dict.search.categories as Record<SearchResultType, string>;
---

<BaseLayout locale={locale}>
  <section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 bg-gradient-to-br from-accent-muted/40 via-surface to-surface dark:from-accent-muted/20" />
    <div class="absolute inset-0 bg-grid opacity-60" aria-hidden="true" />
    <div class="container-app relative grid gap-10 py-16 sm:py-24 lg:grid-cols-[minmax(0,1fr)_minmax(360px,520px)] lg:items-center">
      <div class="max-w-3xl animate-slide-up">
        <span class="badge-emergency mb-4 inline-flex items-center gap-2">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emergency opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emergency"></span>
          </span>
          {locale === "es" ? "24 jun 2026 — Estado de emergencia" : "Jun 24, 2026 — State of emergency"}
        </span>
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl lg:text-6xl">
          {t("home.banner.title")}
        </h1>
        <p class="mt-6 text-lg text-ink-secondary sm:text-xl">
          {t("home.banner.subtitle")}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`/${locale}/centros-ayuda`} class="btn-primary">
            {t("home.banner.cta")}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href={`/${locale}/voluntarios`} class="btn-secondary">
            {t("home.banner.secondary")}
          </a>
        </div>
        <div class="mt-10">
          <GlobalSearch
            client:load
            locale={locale}
            index={searchIndex}
            labels={{
              placeholder: t("search.placeholder"),
              noResults: t("search.noResults"),
              resultsFor: t("search.resultsFor"),
              hint: t("search.hint"),
              external: t("search.external"),
              categories: categoryLabels,
            }}
          />
        </div>
      </div>
      <div class="relative hidden lg:block" aria-hidden="true">
        <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-emergency/25 via-accent/10 to-transparent blur-2xl"></div>
        <div class="relative overflow-hidden rounded-[2rem] border border-white/60 bg-surface shadow-soft">
          <img
            src="/images/headers/emergencia-sismica.svg"
            alt=""
            class="h-[430px] w-full object-cover"
            loading="eager"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/55 via-transparent to-transparent"></div>
          <div class="absolute bottom-5 left-5 right-5 rounded-2xl border border-white/20 bg-white/15 p-4 text-white backdrop-blur">
            <p class="text-sm font-semibold">
              {locale === "es" ? "Respuesta ciudadana en tiempo real" : "Real-time citizen response"}
            </p>
            <p class="mt-1 text-xs text-white/80">
              {locale === "es"
                ? "Mapa, refugios, ayuda y verificación comunitaria en un solo lugar."
                : "Map, shelters, aid and community verification in one place."}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-app -mt-8 relative z-10">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <StatCard value={SEED_HELP_CENTERS.length + "+"} label={t("home.stats.helpCenters")} icon="map-pin" accent="emergency" />
      <StatCard value={SEED_SHELTERS.length + "+"} label={t("home.stats.shelters")} icon="tent" accent="success" />
      <StatCard value={String(SEED_HOSPITALS.length)} label={t("home.stats.hospitals")} icon="hospital" accent="accent" />
      <StatCard value="—" label={t("home.stats.volunteers")} icon="heart" accent="warning" />
    </div>
  </section>

  <section class="container-app py-16">
    <div class="max-w-3xl">
      <span class="eyebrow mb-3">{t("home.about.eyebrow")}</span>
      <h2 class="section-title">{t("home.about.title")}</h2>
      <p class="section-subtitle">{t("home.about.lead")}</p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      <div class="card flex gap-4">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-emergency-muted text-emergency">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-ink">{t("home.about.points.centralizeTitle")}</h3>
          <p class="mt-1 text-sm text-ink-secondary">{t("home.about.points.centralizeDesc")}</p>
        </div>
      </div>
      <div class="card flex gap-4">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-success-muted text-success">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9c1.66 0 3.22.45 4.56 1.24"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-ink">{t("home.about.points.verifyTitle")}</h3>
          <p class="mt-1 text-sm text-ink-secondary">{t("home.about.points.verifyDesc")}</p>
        </div>
      </div>
      <div class="card flex gap-4">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent-muted text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-ink">{t("home.about.points.connectTitle")}</h3>
          <p class="mt-1 text-sm text-ink-secondary">{t("home.about.points.connectDesc")}</p>
        </div>
      </div>
      <div class="card flex gap-4">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-warning-muted text-warning">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-ink">{t("home.about.points.openTitle")}</h3>
          <p class="mt-1 text-sm text-ink-secondary">{t("home.about.points.openDesc")}</p>
        </div>
      </div>
    </div>

    <div class="mt-6 rounded-2xl border border-accent/20 bg-accent-muted/30 p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wide text-accent">{t("home.about.missionTitle")}</h3>
      <p class="mt-2 text-base text-ink-secondary">{t("home.about.mission")}</p>
    </div>
  </section>

  <SiteFootprints locale={locale} />

  <section class="bg-surface-muted border-y border-border">
    <div class="container-app py-16">
      <span class="eyebrow mb-3">{locale === "es" ? "Situación actual" : "Current situation"}</span>
      <h2 class="section-title">{t("home.situation.title")}</h2>
      <p class="section-subtitle">{t("home.situation.content")}</p>

      <div class="mt-10">
        <h3 class="font-semibold text-ink mb-4">{t("home.external.title")}</h3>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <article class="card-interactive group flex flex-col text-sm" id="home-venapp">
            <a href="https://venapp.com" target="_blank" rel="noopener noreferrer" class="flex flex-col flex-1">
              <span class="font-medium text-ink group-hover:text-accent transition-colors">{t("home.external.venapp")}</span>
              <span class="badge-verified mt-2 w-fit">{t("common.verified")}</span>
            </a>
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId="home-venapp"
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </article>
          <article class="card-interactive group flex flex-col text-sm border-success/30 bg-success-muted/30" id="home-bitchat">
            <a href={`/${locale}/recursos#bitchat`} class="flex flex-col flex-1">
              <span class="font-medium text-ink group-hover:text-success transition-colors">{t("home.external.bitchat")}</span>
              <span class="badge bg-success-muted text-success mt-2 w-fit">
                {locale === "es" ? "Sin internet" : "No internet"}
              </span>
            </a>
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId="home-bitchat"
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </article>
          <article class="card-interactive group flex flex-col text-sm" id="home-red-cross">
            <a href="https://www.cruzrojavenezolana.org.ve" target="_blank" rel="noopener noreferrer" class="flex flex-col flex-1">
              <span class="font-medium text-ink group-hover:text-accent transition-colors">{t("home.external.redCross")}</span>
            </a>
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId="home-red-cross"
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </article>
          <article class="card-interactive group flex flex-col text-sm" id="home-inameh">
            <a href="https://www.inameh.gob.ve" target="_blank" rel="noopener noreferrer" class="flex flex-col flex-1">
              <span class="font-medium text-ink group-hover:text-accent transition-colors">{t("home.external.civilProtection")}</span>
            </a>
            <CommunityFeedback
              client:visible
              contentType="external_link"
              contentId="home-inameh"
              locale={locale}
              labels={feedbackLabels}
              confidenceLabels={confidenceLabels}
              compact
            />
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="container-app py-16">
    <AlliedPlatforms
      locale={locale}
      feedbackLabels={feedbackLabels}
      confidenceLabels={confidenceLabels}
    />
  </section>
</BaseLayout>
