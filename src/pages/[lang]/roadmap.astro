---
import RoadmapPage from "@/views/RoadmapPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/roadmap");
if (locale instanceof Response) return locale;
---

<RoadmapPage locale={locale} />
