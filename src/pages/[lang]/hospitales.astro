---
import HospitalesPage from "@/views/HospitalesPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/hospitales");
if (locale instanceof Response) return locale;
---

<HospitalesPage locale={locale} />
