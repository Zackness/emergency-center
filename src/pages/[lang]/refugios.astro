---
import RefugiosPage from "@/views/RefugiosPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/refugios");
if (locale instanceof Response) return locale;
---

<RefugiosPage locale={locale} />
