---
import PrivacidadPage from "@/views/PrivacidadPage.astro";
import {
  resolveSecondaryLocale,
  secondaryLocaleStaticPaths,
} from "@/i18n/page-locale";

export function getStaticPaths() {
  return secondaryLocaleStaticPaths();
}

const locale = resolveSecondaryLocale(Astro, "/privacidad");
if (locale instanceof Response) return locale;
---

<PrivacidadPage locale={locale} />
