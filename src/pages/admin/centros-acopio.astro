---
export const prerender = false;

import AdminLayout from "@/layouts/AdminLayout.astro";
import AdminHelpCentersPanel from "@/components/admin/AdminHelpCentersPanel";
import { requireAdminSession } from "@/lib/admin/page-guard";

const auth = await requireAdminSession(Astro);
if (auth.redirect) return auth.redirect;
---

<AdminLayout
  title="Centros de acopio"
  description="Verifica centros, asigna coordinadores y controla su visibilidad en el directorio público."
  current="centros"
  userEmail={auth.user.email ?? ""}
>
  <AdminHelpCentersPanel client:load />
</AdminLayout>
