---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import { createClient } from "@/lib/supabase/server";
import { getProfileRole } from "@/lib/data";

const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { user } } = await supabase.auth.getUser();

let isAdmin = false;
if (user) {
  const role = await getProfileRole(user.id);
  isAdmin = role === "admin";
}

const error = Astro.url.searchParams.get("error");
---

<BaseLayout locale="es" title="Admin" noEmergencyBar>
  <section class="container-app py-16 max-w-lg mx-auto">
    <div class="card">
      <h1 class="text-2xl font-semibold text-ink mb-2">Emergency Center — Admin</h1>

      {error && (
        <div class="rounded-xl bg-emergency-muted text-emergency p-3 text-sm mb-4">
          {error}
        </div>
      )}

      {!user ? (
        <form method="POST" action="/api/auth/login" class="space-y-4">
          <div>
            <label class="label" for="email">Email</label>
            <input class="input" type="email" id="email" name="email" required />
          </div>
          <div>
            <label class="label" for="password">Contraseña</label>
            <input class="input" type="password" id="password" name="password" required />
          </div>
          <button type="submit" class="btn-primary w-full">Iniciar sesión</button>
        </form>
      ) : !isAdmin ? (
        <div>
          <p class="text-ink-secondary mb-4">No tienes permisos de administrador.</p>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="btn-secondary">Cerrar sesión</button>
          </form>
        </div>
      ) : (
        <div class="space-y-4">
          <p class="text-sm text-ink-secondary">
            Sesión activa: <strong>{user.email}</strong>
          </p>
          <div class="grid gap-2">
            <a href="/es/centros-ayuda/panel" class="btn-secondary text-center">Panel centros de acopio</a>
            <a href="/es/noticias" class="btn-secondary text-center">Gestionar noticias</a>
            <a href="/es/danos" class="btn-secondary text-center">Ver mapa de daños</a>
          </div>
          <form method="POST" action="/api/auth/logout">
            <button type="submit" class="btn-ghost text-emergency">Cerrar sesión</button>
          </form>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
