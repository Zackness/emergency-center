# URL pública del sitio (producción). En Vercel puedes omitirla: se usa VERCEL_URL automáticamente.
# PUBLIC_SITE_URL=https://tu-dominio.com

# Auth (API REST — prefijo PUBLIC_ obligatorio en Astro)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Solo servidor (opcional, no usar en frontend)
SUPABASE_SECRET_KEY=your-secret-key

# Escrituras públicas vía formularios (POST /api/*). Por defecto desactivado.
# Actívalo solo en el hosting de producción cuando quieras aceptar registros ciudadanos.
ALLOW_PUBLIC_WRITES=false

# Sincronización de desaparecidos y mapa de daños (solo servidor / cron)
SYNC_SECRET=generate-a-long-random-string

# Scripts locales (sync:*, db:push): nunca apuntes DATABASE_URL de producción sin querer.
# CONFIRM_PRODUCTION_DB=1
# SUPABASE_PROJECT_REF=your-project-ref

# Google Maps — importación de hospitales (solo servidor / script fetch:hospitals:google)
# Habilita "Places API (New)" en Google Cloud Console
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mapa de daños — API pública de terremotovenezuela.com (solo servidor)
TERREMOTO_VZLA_SUPABASE_URL=https://jckifxsdlnsvbztxydes.supabase.co
TERREMOTO_VZLA_SUPABASE_KEY=your-publishable-key-from-terremotovenezuela

# Bunny CDN — subida de imágenes (misma Storage Zone que StartupVen / CALETAS)
# BUNNY_STORAGE_ZONE_NAME=frankens-monster
# BUNNY_API_KEY=
# BUNNYCDN_API_KEY=
# BUNNY_BASE_URL=https://storage.bunnycdn.com
# BUNNY_PUBLIC_BASE_URL=https://frankens-monster.b-cdn.net

# Opcional: proteger listado/borrado en GET/DELETE /api/upload
# UPLOAD_SECRET=

# Prisma → PostgreSQL de Supabase
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
