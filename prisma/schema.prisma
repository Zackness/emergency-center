generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  editor
  volunteer

  @@map("user_role")
}

enum OperationalStatus {
  operational
  limited
  closed
  unknown

  @@map("operational_status")
}

enum HelpCenterType {
  church
  community
  university
  government
  ngo

  @@map("help_center_type")
}

enum AgencyCategory {
  civil_protection
  firefighters
  red_cross
  police
  government
  mayor

  @@map("agency_category")
}

enum LinkCategory {
  missing
  pets
  news
  official
  tools

  @@map("link_category")
}

enum ContentLocale {
  es
  en
  both

  @@map("content_locale")
}

enum GuidePhase {
  before
  during
  after

  @@map("guide_phase")
}

enum SourceRegistrationType {
  official
  community
  ngo
  social_media
  form

  @@map("source_registration_type")
}

enum ExternalSourceStatus {
  active
  down
  unverified

  @@map("external_source_status")
}

enum MissingPersonVerificationStatus {
  unverified
  family_verified
  org_verified
  found
  deceased

  @@map("missing_person_verification_status")
}

enum DuplicateMatchStatus {
  pending
  confirmed
  rejected

  @@map("duplicate_match_status")
}

enum DamageSeverity {
  collapsed
  damaged
  evacuated

  @@map("damage_severity")
}

enum VolunteerRegistrationStatus {
  pending
  active
  inactive

  @@map("volunteer_registration_status")
}

enum InventoryMovementType {
  inbound
  outbound
  adjustment

  @@map("inventory_movement_type")
}

enum FeatureSuggestionStatus {
  pending
  reviewed
  accepted
  rejected

  @@map("feature_suggestion_status")
}

enum NewsVoteVerdict {
  credible
  false

  @@map("news_vote_verdict")
}

enum CommunityContentType {
  help_center
  hospital
  shelter
  agency
  damage_report
  missing_person
  news
  solidarity_company
  external_link

  @@map("community_content_type")
}

enum CommunityVoteVerdict {
  credible
  false

  @@map("community_vote_verdict")
}

model Profile {
  id        String   @id @db.Uuid
  email     String
  fullName  String?  @map("full_name")
  role      UserRole @default(volunteer)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  helpCenters    HelpCenter[]
  hospitals      Hospital[]
  shelters       Shelter[]
  agencies       Agency[]
  externalLinks   ExternalLink[]
  newsItems       NewsItem[]
  missingPersons  MissingPerson[]
  damageReports   DamageReport[]
  helpCenterCoordinators HelpCenterCoordinator[]
  inventoryMovements     InventoryMovement[] @relation("RecordedBy")
  communityVotes         CommunityCredibilityVote[]
  communityComments      CommunityComment[]

  @@map("profiles")
}

model HelpCenter {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  type        HelpCenterType @default(community)
  state       String
  city        String
  address     String
  latitude    Float
  longitude   Float
  phone       String?
  email       String?
  schedule    String?
  accepts     String[]       @default([])
  imageUrl    String?        @map("image_url")
  imageUrls   String[]       @default([]) @map("image_urls")
  isVerified  Boolean        @default(false) @map("is_verified")
  isActive    Boolean        @default(true) @map("is_active")
  createdById String?        @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy Profile? @relation(fields: [createdById], references: [id])

  volunteerRegistrations VolunteerRegistration[]
  inventoryItems         InventoryItem[]
  coordinators           HelpCenterCoordinator[]

  @@index([state])
  @@map("help_centers")
}

model Hospital {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  state       String
  city        String
  address     String
  latitude    Float
  longitude   Float
  phone       String?
  status      OperationalStatus @default(unknown)
  services    String[]          @default([])
  notes       String?
  socialLinks Json              @default("[]") @map("social_links") @db.JsonB
  isVerified  Boolean           @default(false) @map("is_verified")
  isActive    Boolean           @default(true) @map("is_active")
  createdById String?           @map("created_by") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy Profile? @relation(fields: [createdById], references: [id])

  @@index([status])
  @@map("hospitals")
}

model DamageReport {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  severity        DamageSeverity @default(damaged)
  state           String
  city            String
  address         String?
  latitude        Float
  longitude       Float
  description     String?
  reporterName    String?        @map("reporter_name")
  reporterContact String?        @map("reporter_contact")
  sourceName      String?        @map("source_name")
  sourceUrl       String?        @map("source_url")
  externalReference String?      @map("external_reference")
  externalSource    String?      @map("external_source")
  zone              String?
  imageUrls         String[]     @default([]) @map("image_urls")
  sourceSyncedAt    DateTime?    @map("source_synced_at") @db.Timestamptz(6)
  isVerified      Boolean        @default(false) @map("is_verified")
  isActive        Boolean        @default(true) @map("is_active")
  createdById     String?        @map("created_by") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy Profile? @relation(fields: [createdById], references: [id])

  @@unique([externalSource, externalReference])
  @@index([severity])
  @@index([state])
  @@map("damage_reports")
}

model Shelter {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  state            String
  city             String
  address          String
  latitude         Float
  longitude        Float
  phone            String?
  capacity         Int?
  currentOccupancy Int?     @map("current_occupancy")
  services         String[] @default([])
  schedule         String?
  isVerified       Boolean  @default(false) @map("is_verified")
  isActive         Boolean  @default(true) @map("is_active")
  createdById      String?  @map("created_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy Profile? @relation(fields: [createdById], references: [id])

  @@index([state])
  @@map("shelters")
}

model Agency {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  category    AgencyCategory
  state       String?
  description String?
  phone       String?
  email       String?
  website     String?
  socialLinks Json           @default("[]") @map("social_links") @db.JsonB
  isVerified  Boolean        @default(false) @map("is_verified")
  isActive    Boolean        @default(true) @map("is_active")
  createdById String?        @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy Profile? @relation(fields: [createdById], references: [id])

  @@map("agencies")
}

model ExternalLink {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  url         String
  category    LinkCategory
  locale      ContentLocale @default(both)
  isVerified  Boolean       @default(false) @map("is_verified")
  isActive    Boolean       @default(true) @map("is_active")
  sortOrder   Int           @default(0) @map("sort_order")
  createdById String?       @map("created_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy Profile? @relation(fields: [createdById], references: [id])

  @@index([category])
  @@map("external_links")
}

model NewsItem {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  summary     String
  source      String
  sourceUrl   String        @map("source_url")
  publishedAt DateTime      @map("published_at") @db.Timestamptz(6)
  locale      ContentLocale @default(both)
  isVerified  Boolean       @default(false) @map("is_verified")
  isActive    Boolean       @default(true) @map("is_active")
  createdById String?       @map("created_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy Profile? @relation(fields: [createdById], references: [id])
  credibilityVotes NewsCredibilityVote[]

  @@index([publishedAt(sort: Desc)])
  @@map("news_items")
}

model NewsCredibilityVote {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  newsItemId String          @map("news_item_id") @db.Uuid
  verdict    NewsVoteVerdict
  voterToken String          @map("voter_token")
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  newsItem NewsItem @relation(fields: [newsItemId], references: [id], onDelete: Cascade)

  @@unique([newsItemId, voterToken])
  @@index([newsItemId])
  @@map("news_credibility_votes")
}

model EmergencyNumber {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  labelEs   String  @map("label_es")
  labelEn   String  @map("label_en")
  number    String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@map("emergency_numbers")
}

model VolunteerRegistration {
  id           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  city         String
  state        String
  profession   String
  specialty    String?
  vehicle      String?
  availability String
  phone        String
  email        String
  location     String?
  notes        String?
  helpCenterId String?                     @map("help_center_id") @db.Uuid
  status       VolunteerRegistrationStatus @default(pending)
  isActive     Boolean                     @default(true) @map("is_active")
  createdAt    DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  helpCenter HelpCenter? @relation(fields: [helpCenterId], references: [id], onDelete: SetNull)

  @@index([helpCenterId])
  @@index([status])
  @@map("volunteer_registrations")
}

model CompanyRegistration {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName String   @map("company_name")
  contactName String   @map("contact_name")
  phone       String
  email       String
  state       String
  city        String
  resources   String[] @default([])
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("company_registrations")
}

model ResourceGuide {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titleEs   String     @map("title_es")
  titleEn   String     @map("title_en")
  contentEs String     @map("content_es")
  contentEn String     @map("content_en")
  phase     GuidePhase
  fileUrl   String?    @map("file_url")
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("resource_guides")
}

model ExternalSource {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String                 @unique
  name             String
  description      String?
  url              String
  registrationType SourceRegistrationType @default(community) @map("registration_type")
  approximateCount Int?                   @map("approximate_count")
  countPending     Int?                   @map("count_pending")
  countLocated     Int?                   @map("count_located")
  lastUpdatedAt    DateTime?              @map("last_updated_at") @db.Timestamptz(6)
  status           ExternalSourceStatus   @default(unverified)
  isVerified       Boolean                @default(false) @map("is_verified")
  isActive         Boolean                @default(true) @map("is_active")
  sortOrder        Int                    @default(0) @map("sort_order")
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  externalRecords ExternalRecord[]

  @@index([status])
  @@map("external_sources")
}

model MissingPerson {
  id                 String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName           String                          @map("full_name")
  nationalId         String?                         @map("national_id")
  age                Int?
  gender             String?
  state              String
  city               String
  lastSeenLocation   String?                         @map("last_seen_location")
  lastSeenAt         DateTime?                       @map("last_seen_at") @db.Timestamptz(6)
  description        String?
  photoUrl           String?                         @map("photo_url")
  contactName        String                          @map("contact_name")
  contactPhone       String                          @map("contact_phone")
  contactEmail       String?                         @map("contact_email")
  verificationStatus MissingPersonVerificationStatus @default(unverified) @map("verification_status")
  isActive           Boolean                         @default(true) @map("is_active")
  createdById        String?                         @map("created_by") @db.Uuid
  createdAt          DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy              Profile?         @relation(fields: [createdById], references: [id])
  externalRecords        ExternalRecord[]
  primaryDuplicateMatches DuplicateMatch[] @relation("PrimaryPerson")
  matchedDuplicateMatches DuplicateMatch[] @relation("MatchedPerson")

  @@index([verificationStatus])
  @@index([state])
  @@index([nationalId])
  @@map("missing_persons")
}

model ExternalRecord {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  missingPersonId   String?   @map("missing_person_id") @db.Uuid
  sourceId          String    @map("source_id") @db.Uuid
  externalUrl       String?   @map("external_url")
  externalReference String?   @map("external_reference")
  displayName       String    @map("display_name")
  notes             String?
  lastVerifiedAt    DateTime? @map("last_verified_at") @db.Timestamptz(6)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  missingPerson        MissingPerson?  @relation(fields: [missingPersonId], references: [id], onDelete: SetNull)
  source               ExternalSource  @relation(fields: [sourceId], references: [id])
  matchedDuplicateMatches DuplicateMatch[]

  @@index([missingPersonId])
  @@index([sourceId])
  @@map("external_records")
}

model DuplicateMatch {
  id                      String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  primaryPersonId         String               @map("primary_person_id") @db.Uuid
  matchedPersonId         String?              @map("matched_person_id") @db.Uuid
  matchedExternalRecordId String?              @map("matched_external_record_id") @db.Uuid
  confidence              Float?
  status                  DuplicateMatchStatus @default(pending)
  notes                   String?
  reviewedAt              DateTime?            @map("reviewed_at") @db.Timestamptz(6)
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  primaryPerson         MissingPerson   @relation("PrimaryPerson", fields: [primaryPersonId], references: [id], onDelete: Cascade)
  matchedPerson         MissingPerson?  @relation("MatchedPerson", fields: [matchedPersonId], references: [id], onDelete: SetNull)
  matchedExternalRecord ExternalRecord? @relation(fields: [matchedExternalRecordId], references: [id], onDelete: SetNull)

  @@index([primaryPersonId])
  @@index([status])
  @@map("duplicate_matches")
}

model HelpCenterCoordinator {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId    String   @map("profile_id") @db.Uuid
  helpCenterId String   @map("help_center_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  helpCenter HelpCenter @relation(fields: [helpCenterId], references: [id], onDelete: Cascade)

  @@unique([profileId, helpCenterId])
  @@index([helpCenterId])
  @@map("help_center_coordinators")
}

model InventoryItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  helpCenterId   String   @map("help_center_id") @db.Uuid
  name           String
  category       String
  unit           String   @default("unidad")
  quantityOnHand Float    @default(0) @map("quantity_on_hand")
  minimumStock   Float?   @map("minimum_stock")
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  helpCenter HelpCenter          @relation(fields: [helpCenterId], references: [id], onDelete: Cascade)
  movements  InventoryMovement[]

  @@index([helpCenterId])
  @@index([category])
  @@map("inventory_items")
}

model InventoryMovement {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId       String                @map("item_id") @db.Uuid
  type         InventoryMovementType
  quantity     Float
  donorName    String?               @map("donor_name")
  destination  String?
  notes        String?
  recordedById String?               @map("recorded_by") @db.Uuid
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  item       InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  recordedBy Profile?      @relation("RecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([createdAt(sort: Desc)])
  @@map("inventory_movements")
}

model FeatureSuggestion {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  category    String?
  contactName String?                  @map("contact_name")
  contactEmail String?                 @map("contact_email")
  status      FeatureSuggestionStatus  @default(pending)
  isActive    Boolean                  @default(true) @map("is_active")
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("feature_suggestions")
}

model CommunityCredibilityVote {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentType CommunityContentType @map("content_type")
  contentId   String               @map("content_id")
  verdict     CommunityVoteVerdict
  voterToken  String               @map("voter_token")
  profileId   String?              @map("profile_id") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([contentType, contentId, voterToken])
  @@index([contentType, contentId])
  @@map("community_credibility_votes")
}

model CommunityComment {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentType CommunityContentType @map("content_type")
  contentId   String               @map("content_id")
  body        String
  authorName  String?              @map("author_name")
  voterToken  String?              @map("voter_token")
  profileId   String?              @map("profile_id") @db.Uuid
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([contentType, contentId, createdAt(sort: Desc)])
  @@map("community_comments")
}
